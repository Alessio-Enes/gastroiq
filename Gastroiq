function initSimulator() { updateSim(); updateBreakeven(); }

function updateSim() {
  const preis=parseInt(document.getElementById('sim-preis').value)||0;
  const we=parseInt(document.getElementById('sim-we').value)||0;
  const personal=parseInt(document.getElementById('sim-personal').value)||0;
  const gaeste=parseInt(document.getElementById('sim-gaeste').value)||0;
  const tage=parseInt(document.getElementById('sim-tage').value)||0;
  document.getElementById('sim-preis-val').textContent=(preis>=0?'+':'')+preis+'%';
  document.getElementById('sim-we-val').textContent='-'+we+'%';
  document.getElementById('sim-personal-val').textContent='-'+personal+'%';
  document.getElementById('sim-gaeste-val').textContent=(gaeste>=0?'+':'')+gaeste+'%';
  document.getElementById('sim-tage-val').textContent=tage+' Tag'+(tage!==1?'e':'');
}

function resetSim() {
  ['sim-preis','sim-we','sim-personal','sim-gaeste','sim-tage'].forEach(id=>document.getElementById(id).value=0);
  updateSim();
  document.getElementById('sim-result').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--ink3)"><p style="font-size:.85rem">Zurückgesetzt</p></div>';
  destroyChart('chart-simulator');
}

function runSimulation() {
  const m = getCurrentMonth(); const d = getMonthData(m);
  if(d.umsatz===0){toast('Erst Tageseinträge erfassen');return;}

  const preis=parseInt(document.getElementById('sim-preis').value)||0;
  const we=parseInt(document.getElementById('sim-we').value)||0;
  const personal=parseInt(document.getElementById('sim-personal').value)||0;
  const gaeste=parseInt(document.getElementById('sim-gaeste').value)||0;
  const tage=parseInt(document.getElementById('sim-tage').value)||0;

  const tageFaktor=tage>0?(state.settings.tage-tage)/state.settings.tage:1;
  const simUmsatz=d.umsatz*(1+preis/100)*(1+gaeste/100)*tageFaktor;
  const simWarenein=d.einkaufGesamt*(1-we/100)*(1+gaeste/100)*tageFaktor;
  const simPersonal=d.personalGesamt*(1-personal/100)*tageFaktor;
  const simFixkosten=d.fixkostenGesamt;
  const simDB=simUmsatz-simWarenein;
  const simEBIT=simUmsatz-simWarenein-simPersonal-simFixkosten;
  const deltaEBIT=simEBIT-d.ebit;
  const ebitColor=simEBIT>=0?'var(--green)':'var(--red)';

  document.getElementById('sim-result').innerHTML = `
    <div style="display:flex;flex-direction:column;gap:.8rem">
      ${[
        {label:'Umsatz',ist:d.umsatz,sim:simUmsatz},
        {label:'Zutatenkosten',ist:d.einkaufGesamt,sim:simWarenein},
        {label:'Personalkosten',ist:d.personalGesamt,sim:simPersonal},
        {label:'Rohgewinn',ist:d.db,sim:simDB},
        {label:'Betriebsergebnis',ist:d.ebit,sim:simEBIT},
      ].map(r=>{
        const delta=r.sim-r.ist;
        const good=(r.label==='Zutatenkosten'||r.label==='Personalkosten')?delta<0:delta>=0;
        return `<div style="display:flex;justify-content:space-between;align-items:center;padding:.5rem 0;border-bottom:1px solid var(--border)">
          <span style="font-size:.82rem;font-weight:600">${r.label}</span>
          <div style="text-align:right;display:flex;align-items:center;gap:.8rem">
            <span style="font-size:.75rem;color:var(--ink3)">${fmtEur(r.ist)}</span>
            <span style="font-size:.9rem;font-weight:800;color:${r.label==='Betriebsergebnis'?ebitColor:'var(--ink)'}">${fmtEur(r.sim)}</span>
            <span style="font-size:.72rem;font-weight:700;color:${good?'var(--green)':'var(--red)'}">${delta>=0?'+':''}${fmtEur(delta)}</span>
          </div>
        </div>`;
      }).join('')}
      <div style="background:${simEBIT>=0?'var(--green-light)':'var(--red-light)'};border-radius:8px;padding:.8rem;margin-top:.3rem;text-align:center">
        <div style="font-size:.72rem;font-weight:700;color:${ebitColor};text-transform:uppercase;letter-spacing:.06em">Was sich ändert</div>
        <div style="font-size:1.6rem;font-weight:900;color:${ebitColor}">${deltaEBIT>=0?'+':''}${fmtEur(deltaEBIT)}</div>
        <div style="font-size:.72rem;color:${ebitColor}">${deltaEBIT>=0?'mehr Gewinn':'weniger in der Kasse'}</div>
      </div>
    </div>`;

  destroyChart('chart-simulator');
  const ctx = document.getElementById('chart-simulator');
  if(ctx) dashCharts['chart-simulator'] = new Chart(ctx,{
    type:'bar', data:{
      labels:['Umsatz','Zutaten','Personal','Fixkosten','Ergebnis'],
      datasets:[
        {label:'Aktuell',data:[d.umsatz,d.einkaufGesamt,d.personalGesamt,d.fixkostenGesamt,d.ebit],backgroundColor:'rgba(37,99,235,.4)',borderColor:'rgba(37,99,235,.8)',borderWidth:2},
        {label:'Simulation',data:[simUmsatz,simWarenein,simPersonal,simFixkosten,simEBIT],backgroundColor:['rgba(22,163,74,.4)','rgba(234,88,12,.4)','rgba(220,38,38,.4)','rgba(124,58,237,.4)',simEBIT>=0?'rgba(22,163,74,.6)':'rgba(220,38,38,.6)'],borderColor:['#16a34a','#ea580c','#dc2626','#7c3aed',simEBIT>=0?'#16a34a':'#dc2626'],borderWidth:2},
      ]
    }, options:{...chartOpts(), plugins:{legend:{display:true}}}
  });
  toast('✓ Simulation berechnet');
}


