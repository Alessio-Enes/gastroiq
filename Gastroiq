function initBriefing() {
  const days = ['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'];
  const now = new Date();
  document.getElementById('br-datum').textContent = days[now.getDay()]+', '+now.toLocaleDateString('de-DE');
  const m = getCurrentMonth();
  const d = getMonthData(m);
  const te = state.tageseintraege.sort((a,b)=>b.datum.localeCompare(a.datum));
  const gestern = te[0];
  document.getElementById('br-gestern').textContent = gestern ? fmtEur(gestern.umsatz) : '–';
  const ziel = (d.tageCount>0 ? d.umsatz/d.tageCount : 1200)*1.05;
  document.getElementById('br-ziel').textContent = fmtEur(ziel);

  const vb = state.verbrauch;
  const katMap = {};
  vb.forEach(v=>{ katMap[v.kategorie]=(katMap[v.kategorie]||0)+(v.einkauf||0); });
  const sorted = Object.entries(katMap).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const dayFactor = [0.7,0.9,0.85,0.9,1.0,1.2,1.1][now.getDay()];
  const el = document.getElementById('einkaufsliste-heute');
  if(sorted.length>0) {
    el.innerHTML = sorted.map(([k,v])=>`<div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid var(--border);font-size:.82rem"><span>📦 ${k}</span><span style="font-weight:700">${fmtEur(v/30*dayFactor*1.1)}</span></div>`).join('')+`<div style="font-size:.72rem;color:var(--ink3);margin-top:.5rem">Basierend auf deinem Durchschnittsverbrauch</div>`;
  } else { el.innerHTML = '<p style="color:var(--ink3);font-size:.82rem">Verbrauchsdaten erfassen für Einkaufsplanung.</p>'; }

  const alerts = [];
  if(d.foodCostPct>(state.settings.fcZiel||28)) alerts.push({icon:'🔴',text:`Zutatenkosten ${fmtPct(d.foodCostPct)} – heute bewusst einkaufen`});
  if(d.personalPct>(state.settings.pkZiel||33)) alerts.push({icon:'⚠️',text:`Personalkosten ${fmtPct(d.personalPct)} – Schichtplan für heute prüfen`});
  if(gestern && gestern.umsatz<ziel*0.7) alerts.push({icon:'📉',text:`Gestern war schwach (${fmtEur(gestern.umsatz)}) – heute aktiv Gäste ansprechen`});
  if(now.getDay()===5||now.getDay()===6) alerts.push({icon:'📈',text:'Wochenende: Desserts & Getränke aktiv empfehlen!'});
  if(alerts.length===0) alerts.push({icon:'✅',text:'Alles im grünen Bereich – weiter so!'});
  document.getElementById('sofortmassnahmen').innerHTML = alerts.map(a=>`<div style="display:flex;gap:.6rem;padding:.5rem 0;border-bottom:1px solid var(--border);font-size:.82rem"><span>${a.icon}</span><span>${a.text}</span></div>`).join('');
}

