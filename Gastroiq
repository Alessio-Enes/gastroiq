// ── STEP NAVIGATION ──────────────────────────────────────────
function csvGoTo(step) {
  csvState.step = step;
  document.querySelectorAll('.csv-step').forEach((el,i) => el.classList.toggle('active', i+1===step));

  // Update step dots
  for (let i = 1; i <= 4; i++) {
    const dot = document.getElementById('sdot-' + i);
    if (!dot) continue;
    dot.className = 'step-dot' + (i < step ? ' done' : i === step ? ' active' : '');
    if (i < step) dot.querySelector('span').textContent = '✓';
    else dot.querySelector('span').textContent = i;
  }

  const btnBack = document.getElementById('csv-btn-back');
  const btnNext = document.getElementById('csv-btn-next');

  if (step === 1) {
    btnBack.style.display = 'none';
    btnNext.textContent = 'Weiter →';
    btnNext.style.display = '';
    csvRenderProfiles();
  } else if (step === 2) {
    btnBack.style.display = '';
    btnNext.textContent = 'Weiter →';
    btnNext.style.display = '';
    csvRenderColMap();
  } else if (step === 3) {
    btnBack.style.display = '';
    if (csvState.conflicts.length === 0) {
      // No conflicts – skip straight to apply
      const result = csvApplyImport();
      csvRenderDone(result);
      csvGoTo(4);
      return;
    }
    btnNext.textContent = 'Import durchführen →';
    btnNext.style.display = '';
    csvRenderConflicts();
  } else if (step === 4) {
    btnBack.style.display = 'none';
    btnNext.textContent = 'Schließen';
    btnNext.onclick = csvCancel;
  }
}

function csvNext() {
  if (csvState.step === 1) {
    if (!csvState.rows.length) { toast('Bitte zuerst eine CSV-Datei hochladen'); return; }
    csvGoTo(2);
  } else if (csvState.step === 2) {
    if (csvState.posMode) {
      // POS mode: use pre-aggregated result
      if (!csvState._posResult || !csvState._posResult.aggregated.length) {
        toast('Keine Daten nach Aggregation – bitte CSV prüfen'); return;
      }
      csvAnalyzeConflictsPOS();
    } else {
      if (!csvState.colMap.datum) { toast('Bitte die Datums-Spalte zuordnen'); return; }
      if (!csvState.colMap.umsatz) { toast('Bitte die Umsatz-Spalte zuordnen'); return; }
      csvAnalyzeConflicts();
    }
    csvGoTo(3);
  } else if (csvState.step === 3) {
    const result = csvState.posMode ? csvApplyImportPOS() : csvApplyImport();
    csvRenderDone(result);
    csvGoTo(4);
  }
}

function csvBack() {
  if (csvState.step > 1) csvGoTo(csvState.step - 1);
}

function csvCancel() {
  closeModal('modal-csv');
  // Reset after small delay
  setTimeout(() => {
    csvState.step = 1;
    csvState.rawText = '';
    csvState.headers = [];
    csvState.rows = [];
    csvState.conflicts = [];
    csvState.newRows = [];
    document.getElementById('csv-file-input').value = '';
    csvGoTo(1);
    // Re-register next button click
    document.getElementById('csv-btn-next').onclick = csvNext;
  }, 300);
}

function csvRenderDone(result) {
  const allRows = [...csvState.newRows, ...csvState.conflicts.map(c => c.incoming)];
  const dates = allRows.map(r => r.datum).sort();

  document.getElementById('import-summary-grid').innerHTML = `
    <div class="imp-stat"><div class="imp-stat-num" style="color:var(--green)">${result.imported}</div><div class="imp-stat-lbl">Neu importiert</div></div>
    <div class="imp-stat"><div class="imp-stat-num" style="color:var(--primary)">${result.overwritten}</div><div class="imp-stat-lbl">Überschrieben</div></div>
    <div class="imp-stat"><div class="imp-stat-num" style="color:var(--yellow)">${result.merged}</div><div class="imp-stat-lbl">Gemittelt</div></div>
    <div class="imp-stat"><div class="imp-stat-num" style="color:var(--ink4)">${result.skipped}</div><div class="imp-stat-lbl">Übersprungen</div></div>
  `;
  document.getElementById('import-date-range').textContent =
    dates.length ? `Importierter Zeitraum: ${dates[0]} bis ${dates[dates.length-1]}` : '';

  const totalImported = result.imported + result.overwritten + result.merged;
  const posNote = result.posMode
    ? `<br><br><strong style="color:var(--orange)">⚠️ Nächster Schritt: Wareneinsatz ergänzen</strong><br>
       Die ${totalImported} importierten Tage enthalten noch keinen Wareneinsatz (POS-Systeme liefern diese Daten nicht). 
       Bitte trage ihn in der Tageserfassung pro Tag nach – er ist für die Food-Cost-Berechnung erforderlich.
       <br>Tage mit fehlendem Wareneinsatz sind mit <strong>⚠️</strong> markiert.`
    : '';

  document.getElementById('import-done-detail').innerHTML =
    `<strong>Historische Daten:</strong> Alle manuell eingetragenen Daten außerhalb des Import-Zeitraums sind unverändert. 
    ${result.skipped > 0 ? `<br>${result.skipped} Einträge wurden auf Ihre Anweisung hin nicht überschrieben.` : ''}
    ${result.merged > 0 ? `<br>${result.merged} Einträge wurden gemittelt (manuell + import).` : ''}
    ${posNote}`;
}

// ── IMPORT LOG (shown in settings) ──────────────────────────
function renderImportLog() {
  const el = document.getElementById('import-log-container');
  if (!el) return;
  const log = (state.importLog || []).slice(0, 20);
  if (log.length === 0) {
    el.innerHTML = '<div style="text-align:center;padding:1.5rem;color:var(--ink3);font-size:.82rem">Noch kein Import durchgeführt</div>';
    return;
  }
  el.innerHTML = log.map(e => {
    const dt = new Date(e.ts);
    const dtStr = dt.toLocaleDateString('de-DE') + ', ' + dt.toLocaleTimeString('de-DE', {hour:'2-digit', minute:'2-digit'});
    const range = e.dateFrom ? `${e.dateFrom} – ${e.dateTo}` : '';
    return `<div class="import-log-row">
      <div class="import-log-icon" style="background:var(--surface2);border:1px solid var(--border)">
        <svg viewBox="0 0 24 24" style="width:14px;height:14px;fill:none;stroke:var(--ink3);stroke-width:2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
      </div>
      <div style="flex:1">
        <div style="font-size:.82rem;font-weight:600;color:var(--ink)">${e.fileName || 'CSV-Import'}</div>
        <div style="font-size:.72rem;color:var(--ink3);margin-top:1px">${range}</div>
      </div>
      <div style="text-align:right;flex-shrink:0">
        <div style="font-size:.78rem;font-weight:700;color:var(--ink)">+${e.newRows} neu · ${e.overwritten} ersetzt · ${e.merged} gemittelt · ${e.skipped} skip</div>
        <div class="log-ts">${dtStr}</div>
      </div>
    </div>`;
  }).join('');
}

// ── RESET DATA ───────────────────────────────────────────────
function resetAllData() {
  if (!confirm('Wirklich ALLE Daten löschen?\n\nGerichte, Mitarbeiter, Tageseinträge, Fixkosten, Wareneinkauf – alles wird zurückgesetzt.\n\nDieser Schritt kann nicht rückgängig gemacht werden.')) return;
  state.gerichte = [];
  state.personal = [];
  state.tageseintraege = [];
  state.verbrauch = [];
  state.fixkosten = [];
  state.shifts = {};
  state.importLog = [];
  save();
  renderDashboard();
  toast('Alle Daten gelöscht – App ist bereit für Echteingaben');
}

function resetOnlyTestData() {
  const confirmText = 'Testdaten entfernen?\n\nDie 22 November-Einträge, 6 Demo-Gerichte und 4 Demo-Mitarbeiter werden gelöscht. Deine eigenen Einträge bleiben erhalten.';
  if (!confirm(confirmText)) return;
  // Only remove seeded entries – keep manually added ones if any have different names
  const demoNames = ['Wiener Schnitzel','Spaghetti Bolognese','Caesar Salat','Vegane Bowl','Lachsfilet','Tiramisu'];
  const demoPers  = ['Klaus M.','Anna S.','Mehmet K.','Julia R.'];
  state.gerichte = state.gerichte.filter(g => !demoNames.includes(g.name));
  state.personal = state.personal.filter(p => !demoPers.includes(p.name));
  // Remove November 2025 entries that came from seedDemo (no source tag = demo)
  state.tageseintraege = state.tageseintraege.filter(t => t.source !== 'demo');
  state.fixkosten = state.fixkosten.filter(f => !(f.monat === '2025-11' && ['Miete','Strom','Gas/Heizung','Versicherung','Buchhaltung'].includes(f.art)));
  state.verbrauch = state.verbrauch.filter(v => !(v.datum === '2025-11-01'));
  save();
  renderDashboard();
  toast('Testdaten entfernt');
}

</script>
</body>
</html>
