const DAY_NAMES = ['Mo','Di','Mi','Do','Fr','Sa','So'];
const DAY_FULL  = ['Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag','Sonntag'];

// Expected demand per day (0-100). Fri/Sat highest, Mon/Tue lowest
const DEMAND_INDEX = { Mo:45, Di:50, Mi:60, Do:70, Fr:95, Sa:90, So:65 };

// How many staff needed per demand level (for ~40 seats)
function staffNeeded(demandPct, sitze) {
  const base = Math.max(2, Math.ceil((sitze || 40) / 15));
  if(demandPct >= 90) return base + 2;
  if(demandPct >= 70) return base + 1;
  if(demandPct >= 50) return base;
  return Math.max(2, base - 1);
}

// Calculate demand for each day factoring in actual data
function getDayDemand() {
  const demand = {...DEMAND_INDEX};
  // Override with actual data if available
  const daySums = {Mo:[], Di:[], Mi:[], Do:[], Fr:[], Sa:[], So:[]};
  const jsToDay = ['So','Mo','Di','Mi','Do','Fr','Sa'];
  state.tageseintraege.forEach(t => {
    if(t.datum && t.umsatz > 0) {
      const d = jsToDay[new Date(t.datum).getDay()];
      if(d) daySums[d].push(t.umsatz);
    }
  });
  // Normalize actual data to 0-100 scale
  const allAvgs = Object.values(daySums).map(arr => arr.length > 0 ? arr.reduce((s,v)=>s+v,0)/arr.length : 0).filter(v => v > 0);
  if(allAvgs.length >= 3) {
    const maxAvg = Math.max(...allAvgs);
    DAY_NAMES.forEach(d => {
      if(daySums[d].length > 0) {
        const avg = daySums[d].reduce((s,v)=>s+v,0) / daySums[d].length;
        demand[d] = Math.round((avg / maxAvg) * 100);
      }
    });
  }
  return demand;
}

function getWeekDates(offset) {
  const now = new Date();
  const dayOfWeek = now.getDay(); // 0=Sun
  const mondayOffset = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;
  const monday = new Date(now);
  monday.setDate(now.getDate() + mondayOffset + (offset * 7));
  const dates = [];
  for(let i = 0; i < 7; i++) {
    const d = new Date(monday);
    d.setDate(monday.getDate() + i);
    dates.push(d);
  }
  return dates;
}

function shiftKey(empId, dateStr) { return empId + '_' + dateStr; }

function shiftWeekOffset(dir) {
  weekOffset += dir;
  renderSchichtplan();
}

