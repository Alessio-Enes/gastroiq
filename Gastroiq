async function saveTageseintrag() {
  const datum   = document.getElementById('te-datum').value;
  const umsatz  = parseFloat(document.getElementById('te-umsatz-inp').value);
  const gaeste  = parseInt(document.getElementById('te-gaeste-inp').value);
  const togo    = parseInt(document.getElementById('te-togo-inp').value) || 0;

  // ── Pflichtfeld-Validierung
  if (!datum) { toast('⛔ Datum ist erforderlich'); document.getElementById('te-datum').focus(); return; }
  const datumObj = new Date(datum);
  const today = new Date(); today.setHours(23,59,59);
  if (datumObj > today) { toast('⛔ Datum liegt in der Zukunft'); return; }
  if (isNaN(umsatz) || umsatz <= 0) { toast('⛔ Umsatz muss größer als 0 sein'); document.getElementById('te-umsatz-inp').focus(); return; }
  if (isNaN(gaeste) || gaeste <= 0) { toast('⛔ Gästeanzahl muss größer als 0 sein'); document.getElementById('te-gaeste-inp').focus(); return; }

  // ── Plausibilitäts-Checks (Warnung, kein Block)
  const avgBon = umsatz / gaeste;
  if (avgBon < 3) {
    if (!confirm(`⚠️ Ø Bon beträgt nur ${avgBon.toFixed(2)} €/Gast – das ist sehr niedrig.\n\nTrotzdem speichern?`)) return;
  }
  if (avgBon > 200) {
    if (!confirm(`⚠️ Ø Bon beträgt ${avgBon.toFixed(2)} €/Gast – das ist sehr hoch.\n\nTrotzdem speichern?`)) return;
  }
  if (umsatz > 50000) {
    if (!confirm(`⚠️ Umsatz von ${umsatz.toFixed(2)} € ist ungewöhnlich hoch.\n\nTrotzdem speichern?`)) return;
  }

  const payload = {
    datum,
    umsatz,
    gaeste,
    togo,
    getraenke: parseFloat(document.getElementById('te-getraenk').value) || 0,
    top_gericht: document.getElementById('te-topgericht').value,
    notiz: document.getElementById('te-notiz').value,
    barUmsatz: parseFloat(document.getElementById('te-bar').value) || 0,
    karteUmsatz: parseFloat(document.getElementById('te-karte').value) || 0,
    digitalUmsatz: parseFloat(document.getElementById('te-digital').value) || 0,
  };

  if(!DEMO_MODE && db && currentUser) {
    const { data, error } = await db.from('tageseintraege').upsert({ ...payload, user_id: currentUser.id }, { onConflict:'datum,user_id' }).select().single();
    if(error) { toast('Fehler: '+error.message); return; }
    state.tageseintraege = state.tageseintraege.filter(t=>t.datum!==datum);
    state.tageseintraege.push(remapTageseintrag(data));
  } else {
    state.tageseintraege = state.tageseintraege.filter(t=>t.datum!==datum);
    state.tageseintraege.push({ id:uid(), datum:payload.datum, umsatz:payload.umsatz, gaeste:payload.gaeste, togo:payload.togo, getraenke:payload.getraenke, topGericht:payload.top_gericht, notiz:payload.notiz, barUmsatz:payload.barUmsatz, karteUmsatz:payload.karteUmsatz, digitalUmsatz:payload.digitalUmsatz, source:'manual' });
    save();
  }
  closeModal('modal-tageseintrag'); renderTageseintraege(); toast('✓ Tag gespeichert');
}

function renderTageseintraege() {
  const m = getCurrentMonth();
  const te = state.tageseintraege.filter(t=>monthStr(t.datum)===m).sort((a,b)=>b.datum.localeCompare(a.datum));
  const umsatzGes = te.reduce((s,t)=>s+(t.umsatz||0),0);
  const gaesteGes = te.reduce((s,t)=>s+(t.gaeste||0),0);
  document.getElementById('te-tage').textContent = te.length;
  document.getElementById('te-umsatz').textContent = fmtEur(umsatzGes);
  document.getElementById('te-gaeste').textContent = gaesteGes;
  document.getElementById('te-avg').textContent = te.length>0?fmtEur(umsatzGes/te.length):'0 €';

  // Data quality widget
  renderDatenqualitaet(m);

  const days = ['So','Mo','Di','Mi','Do','Fr','Sa'];
  document.getElementById('tageserfassung-tbody').innerHTML = te.map(t=>{
    const avg = t.gaeste>0?t.umsatz/t.gaeste:0;
    const togoP = (t.gaeste+t.togo)>0?t.togo/(t.gaeste+t.togo)*100:0;
    const weFlag = t._wareneinsatzFehlt
      ? `<span title="Wareneinsatz fehlt – bitte manuell erfassen" style="color:var(--orange);font-size:.8rem">⚠️</span> `
      : '';
    return `<tr>
      <td class="td-bold">${weFlag}${t.datum.split('-').reverse().join('.')}</td>
      <td><span class="badge badge-blue">${days[new Date(t.datum).getDay()]}</span></td>
      <td class="td-bold">${fmtEur(t.umsatz)}</td><td>${t.gaeste}</td><td>${fmtEur(avg)}</td><td>${fmtPct(togoP)}</td>
      <td>${t.topGericht||'–'}</td>
      <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${t.notiz||''}">${t.notiz||'–'}</td>
      <td><button class="btn btn-sm btn-danger" onclick="deleteTageseintrag('${t.id}')">✕</button></td>
    </tr>`;
  }).join('');
}

async function deleteTageseintrag(id) {
  if(!DEMO_MODE && db) await db.from('tageseintraege').delete().eq('id', id);
  state.tageseintraege=state.tageseintraege.filter(t=>t.id!==id); save(); renderTageseintraege();
}

