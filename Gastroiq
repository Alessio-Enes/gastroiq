function autoSchedule() {
  const demand = getDayDemand();
  const dates = getWeekDates(weekOffset);
  const sitze = state.settings.sitze || 40;

  // Clear current week's shifts
  dates.forEach(d => {
    const ds = d.toISOString().split('T')[0];
    state.personal.forEach(p => { delete state.shifts[shiftKey(p.id, ds)]; });
  });

  // For each day, assign staff based on demand
  dates.forEach((date, dayIdx) => {
    const dayName = DAY_NAMES[dayIdx];
    const ds = date.toISOString().split('T')[0];
    const needed = staffNeeded(demand[dayName], sitze);

    // Sort employees by priority: available + no wish-free first, then wish-free
    const candidates = state.personal
      .map(p => {
        const verfueg = p.verfueg || DAY_NAMES;
        const wunschfrei = p.wunschfrei || [];
        const isAvailable = verfueg.includes(dayName);
        const isWishFree = wunschfrei.includes(dayName);
        // Count how many shifts this person already has this week
        const weekShifts = dates.filter(wd => state.shifts[shiftKey(p.id, wd.toISOString().split('T')[0])]).length;
        // Max days per week based on monthly hours (rough: monthly hours / 8 / 4.3)
        const maxDaysPerWeek = Math.min(6, Math.ceil((p.stunden || 80) / 8 / 4.3));
        return { emp: p, isAvailable, isWishFree, weekShifts, maxDaysPerWeek };
      })
      .filter(c => c.isAvailable && c.weekShifts < c.maxDaysPerWeek)
      .sort((a, b) => {
        // Prefer non-wish-free over wish-free
        if(a.isWishFree !== b.isWishFree) return a.isWishFree ? 1 : -1;
        // Then prefer those with fewer shifts (spread evenly)
        return a.weekShifts - b.weekShifts;
      });

    // Assign up to 'needed' staff
    const toAssign = candidates.slice(0, needed);
    toAssign.forEach(c => {
      const hours = demand[dayName] >= 80 ? 8 : 6;
      state.shifts[shiftKey(c.emp.id, ds)] = { hours, role: c.emp.rolle };
    });
  });

  save();
  renderSchichtplan();
  toast('✓ Automatisch geplant – prüfe und passe an');
}

function renderSchichtplan() {
  const dates = getWeekDates(weekOffset);
  const demand = getDayDemand();
  const sitze = state.settings.sitze || 40;
  const todayStr = new Date().toISOString().split('T')[0];

  // Week label
  const startDate = dates[0].toLocaleDateString('de-DE', {day:'2-digit',month:'short'});
  const endDate = dates[6].toLocaleDateString('de-DE', {day:'2-digit',month:'short',year:'numeric'});
  document.getElementById('sp-week-label').textContent =
    weekOffset === 0 ? 'Diese Woche' : weekOffset === 1 ? 'Nächste Woche' : weekOffset === -1 ? 'Letzte Woche' : startDate + ' – ' + endDate;

  // KPIs
  document.getElementById('sp-mitarbeiter').textContent = state.personal.length;
  let totalHours = 0, totalCost = 0;
  dates.forEach(d => {
    const ds = d.toISOString().split('T')[0];
    state.personal.forEach(p => {
      const s = state.shifts[shiftKey(p.id, ds)];
      if(s) {
        totalHours += s.hours || 0;
        totalCost += (s.hours || 0) * (p.lohn || 0);
      }
    });
  });
  document.getElementById('sp-stunden').textContent = totalHours + ' h';
  document.getElementById('sp-kosten').textContent = fmtEur(totalCost);

  // Coverage & understaffing
  let coveredDays = 0, understaffedDays = [];
  dates.forEach((d, dayIdx) => {
    const dayName = DAY_NAMES[dayIdx];
    const ds = d.toISOString().split('T')[0];
    const assigned = state.personal.filter(p => state.shifts[shiftKey(p.id, ds)]).length;
    const needed = staffNeeded(demand[dayName], sitze);
    if(assigned >= needed) coveredDays++;
    else understaffedDays.push(dayName);
  });
  document.getElementById('sp-abdeckung').textContent = Math.round(coveredDays / 7 * 100) + '%';
  document.getElementById('sp-unterbesetzt').textContent = understaffedDays.length > 0 ? understaffedDays.join(', ') : '✅ Keine';

  // Demand row
  const demandContainer = document.getElementById('demand-row');
  demandContainer.innerHTML = '<div class="demand-cell" style="text-align:left;font-weight:700;font-size:.72rem;color:var(--ink2)">Nachfrage</div>' +
    dates.map((d, i) => {
      const dayName = DAY_NAMES[i];
      const dem = demand[dayName];
      const color = dem >= 85 ? 'var(--red)' : dem >= 65 ? 'var(--orange)' : dem >= 45 ? 'var(--primary)' : 'var(--green)';
      const needed = staffNeeded(dem, sitze);
      const ds = d.toISOString().split('T')[0];
      const assigned = state.personal.filter(p => state.shifts[shiftKey(p.id, ds)]).length;
      const statusColor = assigned >= needed ? 'var(--green)' : assigned > 0 ? 'var(--orange)' : 'var(--red)';
      return `<div class="demand-cell">
        <div class="demand-label" style="color:${color}">${dem}%</div>
        <div class="demand-bar"><div class="demand-fill" style="width:${dem}%;background:${color}"></div></div>
        <div style="font-size:.65rem;margin-top:.25rem;color:${statusColor};font-weight:600">${assigned}/${needed} Leute</div>
      </div>`;
    }).join('');

  // Shift grid
  const container = document.getElementById('shift-grid-container');
  let html = '<div class="shift-grid">';

  // Header row
  html += '<div class="shift-cell shift-header">Mitarbeiter</div>';
  dates.forEach((d, i) => {
    const isToday = d.toISOString().split('T')[0] === todayStr;
    const dayLabel = DAY_NAMES[i];
    const dateLabel = d.toLocaleDateString('de-DE', {day:'2-digit', month:'2-digit'});
    html += `<div class="shift-cell shift-header ${isToday ? 'today-col' : ''}">${dayLabel}<br><span style="font-weight:400;font-size:.62rem">${dateLabel}</span></div>`;
  });

  // Build overlap map: for each assigned cell with times, check overlaps
  const overlapKeys = new Set();
  dates.forEach(d => {
    const ds = d.toISOString().split('T')[0];
    const dayShifts = state.personal
      .filter(p => { const s = state.shifts[shiftKey(p.id, ds)]; return s?.start && s?.end; })
      .map(p => ({ p, s: state.shifts[shiftKey(p.id, ds)] }));
    for(let i = 0; i < dayShifts.length; i++) {
      for(let j = i+1; j < dayShifts.length; j++) {
        const a = dayShifts[i], b = dayShifts[j];
        if(a.p.rolle === b.p.rolle && timesOverlap(a.s.start, a.s.end, b.s.start, b.s.end)) {
          overlapKeys.add(shiftKey(a.p.id, ds));
          overlapKeys.add(shiftKey(b.p.id, ds));
        }
      }
    }
    // Also check fatigue: same employee prev-day night -> today morning
    state.personal.forEach(p => {
      const cur = state.shifts[shiftKey(p.id, ds)];
      if(!cur?.start) return;
      const prev = new Date(ds); prev.setDate(prev.getDate()-1);
      const prevShift = state.shifts[shiftKey(p.id, prev.toISOString().split('T')[0])];
      if(prevShift?.end && prevShift?.start) {
        let pem = timeToMin(prevShift.end); if(pem <= timeToMin(prevShift.start)) pem += 1440;
        const rest = (timeToMin(cur.start) + 1440 - pem) / 60;
        if(rest < 11) overlapKeys.add(shiftKey(p.id, ds));
      }
    });
  });

  // Employee rows
  state.personal.forEach(p => {
    const verfueg = p.verfueg || DAY_NAMES;
    const wunschfrei = p.wunschfrei || [];
    const roleEmoji = p.rolle === 'Küche' ? '👨‍🍳' : p.rolle === 'Service' ? '🙋' : p.rolle === 'Bar' ? '🍸' : '🧹';
    // Wochenstunden summary
    const weekH = dates.reduce((s,d)=>{ const sh=state.shifts[shiftKey(p.id,d.toISOString().split('T')[0])]; return s+(sh?.hours||0); },0);

    html += `<div class="shift-cell shift-name" onclick="openEditMitarbeiter('${p.id}')" title="Klicke zum Bearbeiten" style="cursor:pointer">${roleEmoji} ${p.name}<br><span style="font-weight:400;font-size:.62rem;color:var(--ink3)">${p.rolle} · ${weekH}h/Wo</span></div>`;

    dates.forEach((d, i) => {
      const dayName = DAY_NAMES[i];
      const ds = d.toISOString().split('T')[0];
      const isToday = ds === todayStr;
      const key = shiftKey(p.id, ds);
      const shift = state.shifts[key];
      const isAvailable = verfueg.includes(dayName);
      const isWishFree = wunschfrei.includes(dayName);
      const isOverlap = overlapKeys.has(key);
      const todayCls = isToday ? ' today-col' : '';
      const overlapCls = isOverlap ? ' overlap-warning' : '';

      if(!isAvailable) {
        html += `<div class="shift-cell unavailable${todayCls}">–</div>`;
      } else if(shift) {
        const typeDef = SHIFT_TYPES[shift.type] || SHIFT_TYPES.custom;
        const typeCls = shift.type ? ' shift-' + shift.type : '';
        const timeLabel = shift.start && shift.end ? shift.start + '–' + shift.end : '';
        html += `<div class="shift-cell${typeCls}${todayCls}${overlapCls}" onclick="openShiftModal('${p.id}','${ds}','${dayName}')" title="${typeDef.label}${timeLabel?' ('+timeLabel+')':''} – klicke zum Bearbeiten">
          <span class="shift-type-badge">${typeDef.emoji} ${typeDef.label}</span>
          <input class="shift-hours-input" type="number" min="0.5" max="12" step="0.5" value="${shift.hours}"
            onclick="event.stopPropagation()"
            onchange="updateShiftHours('${p.id}','${ds}',this.value)"
            title="Stunden direkt bearbeiten" />
          ${isOverlap ? '<span style="font-size:.55rem;color:#dc2626;font-weight:800">⚠ Überschn.</span>' : ''}
        </div>`;
      } else if(isWishFree) {
        html += `<div class="shift-cell wish-free${todayCls}" onclick="openShiftModal('${p.id}','${ds}','${dayName}')" title="Wunsch frei – trotzdem einteilen?">Wunsch<br>frei</div>`;
      } else {
        html += `<div class="shift-cell empty${todayCls}" onclick="openShiftModal('${p.id}','${ds}','${dayName}')" title="Klicke zum Einteilen">+</div>`;
      }
    });
  });

  html += '</div>';
  container.innerHTML = html;

  // Mindestbesetzung recommendations
  const mbContainer = document.getElementById('sp-mindestbesetzung');
  mbContainer.innerHTML = DAY_NAMES.map(d => {
    const dem = demand[d];
    const needed = staffNeeded(dem, sitze);
    const color = dem >= 85 ? 'var(--red)' : dem >= 65 ? 'var(--orange)' : 'var(--primary)';
    const label = dem >= 85 ? 'Hochbetrieb' : dem >= 65 ? 'Normal' : 'Ruhig';
    return `<div style="display:flex;justify-content:space-between;align-items:center;padding:.5rem 0;border-bottom:1px solid var(--border)">
      <div>
        <span style="font-size:.82rem;font-weight:600">${d}</span>
        <span class="badge" style="margin-left:.4rem;background:${color}15;color:${color}">${label} (${dem}%)</span>
      </div>
      <span style="font-size:.85rem;font-weight:700">${needed} Leute</span>
    </div>`;
  }).join('');

  // Shift hints
  const hinweise = [];
  // Check for understaffed days
  dates.forEach((d, dayIdx) => {
    const dayName = DAY_NAMES[dayIdx];
    const ds = d.toISOString().split('T')[0];
    const assigned = state.personal.filter(p => state.shifts[shiftKey(p.id, ds)]).length;
    const needed = staffNeeded(demand[dayName], sitze);
    if(assigned < needed) {
      hinweise.push({type:'red', icon:'⚠️', text:`${DAY_FULL[dayIdx]}: Nur ${assigned} von ${needed} Leuten eingeplant. ${demand[dayName] >= 80 ? 'Das ist ein starker Tag – hier wird es eng!' : 'Noch jemanden einteilen?'}`});
    }
  });
  // Check for employees working too many days
  state.personal.forEach(p => {
    const weekShifts = dates.filter(d => state.shifts[shiftKey(p.id, d.toISOString().split('T')[0])]).length;
    const maxDays = Math.min(6, Math.ceil((p.stunden || 80) / 8 / 4.3));
    if(weekShifts > maxDays) {
      hinweise.push({type:'yellow', icon:'⏰', text:`${p.name} hat ${weekShifts} Schichten diese Woche – maximal ${maxDays} wären sinnvoll basierend auf den Vertragsstunden.`});
    }
  });
  // Check wish-free overrides
  dates.forEach((d, dayIdx) => {
    const dayName = DAY_NAMES[dayIdx];
    const ds = d.toISOString().split('T')[0];
    state.personal.forEach(p => {
      if((p.wunschfrei || []).includes(dayName) && state.shifts[shiftKey(p.id, ds)]) {
        hinweise.push({type:'yellow', icon:'💛', text:`${p.name} wollte am ${DAY_FULL[dayIdx]} eigentlich frei haben – ist aber eingeplant.`});
      }
    });
  });

  // Überschneidungs-Hinweise
  overlapKeys.forEach(k => {
    const [empId, dateStr] = k.split('_');
    const emp = state.personal.find(p => p.id === empId);
    if(!emp) return;
    const dateObj = new Date(dateStr+'T12:00:00');
    const dateLabel = dateObj.toLocaleDateString('de-DE',{weekday:'short',day:'2-digit',month:'2-digit'});
    const existing = hinweise.find(h => h.text.includes(emp.name) && h.text.includes(dateLabel));
    if(!existing) {
      hinweise.push({type:'red', icon:'🔴', text:`Überschneidung: ${emp.name} am ${dateLabel} – Schichtzeiten oder Ruhezeit prüfen.`});
    }
  });

  if(hinweise.length === 0) {
    hinweise.push({type:'green', icon:'✅', text:'Alles passt! Ausreichend Personal an allen Tagen eingeplant.'});
  }
  document.getElementById('sp-hinweise').innerHTML = hinweise.slice(0, 6).map(h =>
    `<div class="alert alert-${h.type}" style="margin-bottom:.5rem;padding:.6rem .8rem"><span class="alert-icon">${h.icon}</span><div class="alert-content"><p style="font-size:.78rem">${h.text}</p></div></div>`
  ).join('');
}


