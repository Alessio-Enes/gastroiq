function renderStatistik() {
  const months = ['2025-06','2025-07','2025-08','2025-09','2025-10','2025-11'];
  const mlabels = ['Jun','Jul','Aug','Sep','Okt','Nov'];
  const uData = months.map(m=>getMonthData(m).umsatz);
  const gData = months.map(m=>getMonthData(m).gaeste);
  const bonData = months.map(m=>{const d=getMonthData(m);return d.gaeste>0?d.umsatz/d.gaeste:0;});

  destroyChart('chart-trend-umsatz');
  const ctx1 = document.getElementById('chart-trend-umsatz');
  if(ctx1) dashCharts['chart-trend-umsatz'] = new Chart(ctx1,{ type:'line', data:{ labels:mlabels, datasets:[{ label:'Umsatz (€)', data:uData, borderColor:'#2563eb', backgroundColor:'rgba(37,99,235,.08)', tension:.4, fill:true, pointRadius:4 }]}, options:{...chartOpts(), plugins:{legend:{display:false}}} });

  destroyChart('chart-trend-gaeste');
  const ctx2 = document.getElementById('chart-trend-gaeste');
  if(ctx2) dashCharts['chart-trend-gaeste'] = new Chart(ctx2,{ type:'line', data:{ labels:mlabels, datasets:[
    { label:'Gäste', data:gData, borderColor:'#16a34a', tension:.4, pointRadius:4, yAxisID:'y' },
    { label:'Ø Bon (€)', data:bonData, borderColor:'#ea580c', tension:.4, pointRadius:4, yAxisID:'y2' }
  ]}, options:{...chartOpts(), scales:{ y:{position:'left'}, y2:{position:'right',grid:{drawOnChartArea:false}} }} });

  const dayNames=['So','Mo','Di','Mi','Do','Fr','Sa'];
  const dayCounts = [0,0,0,0,0,0,0];
  state.tageseintraege.forEach(t=>{ if(t.datum){ const d=new Date(t.datum).getDay(); dayCounts[d]+=(t.umsatz||0); }});
  destroyChart('chart-wochentag');
  const ctx3 = document.getElementById('chart-wochentag');
  if(ctx3) dashCharts['chart-wochentag'] = new Chart(ctx3,{ type:'bar', data:{ labels:dayNames, datasets:[{ data:dayCounts, backgroundColor:dayCounts.map((_,i)=>i===5||i===6?'#2563eb':'rgba(37,99,235,.4)') }]}, options:{...chartOpts(), plugins:{legend:{display:false}}} });

  const gerichtCounts = {};
  state.tageseintraege.forEach(t=>{ if(t.topGericht) gerichtCounts[t.topGericht]=(gerichtCounts[t.topGericht]||0)+1; });
  const sorted = Object.entries(gerichtCounts).sort((a,b)=>b[1]-a[1]).slice(0,6);
  document.getElementById('nachfrage-container').innerHTML = sorted.length>0 ? sorted.map(([n,c])=>`
    <div style="margin-bottom:.6rem">
      <div style="display:flex;justify-content:space-between;font-size:.8rem;margin-bottom:.2rem">
        <span style="font-weight:600">${n}</span><span style="color:var(--ink3)">${c}× bestellt</span>
      </div>
      <div class="progress-bar"><div class="progress-fill" style="width:${(c/sorted[0][1]*100)}%;background:var(--primary)"></div></div>
    </div>`).join('') : '<p style="color:var(--ink3);font-size:.82rem">Noch keine Daten. Trag bei der Tageserfassung das Top-Gericht ein.</p>';

  const te = state.tageseintraege.filter(t=>t.umsatz>0);
  if(te.length>3) {
    const vals = te.map(t=>t.umsatz);
    const avg = vals.reduce((s,v)=>s+v,0)/vals.length;
    const std = Math.sqrt(vals.map(v=>Math.pow(v-avg,2)).reduce((s,v)=>s+v,0)/vals.length);
    const ausreisser = te.filter(t=>Math.abs(t.umsatz-avg)>1.5*std).slice(0,4);
    document.getElementById('ausreisser-container').innerHTML = ausreisser.length>0 ? ausreisser.map(t=>{
      const dev = ((t.umsatz-avg)/avg*100);
      return `<div class="alert ${dev>0?'alert-green':'alert-red'}" style="margin-bottom:.5rem">
        <div class="alert-content"><h4>${t.datum.split('-').reverse().join('.')} – ${fmtEur(t.umsatz)}</h4>
        <p>${Math.abs(dev).toFixed(0)}% ${dev>0?'über':'unter'} deinem Durchschnitt${t.notiz?' · '+t.notiz:''}</p></div></div>`;
    }).join('') : '<div class="alert alert-green"><div class="alert-content"><h4>Alles normal</h4><p>Keine ungewöhnlichen Tage – dein Umsatz ist stabil.</p></div></div>';
  } else {
    document.getElementById('ausreisser-container').innerHTML = '<p style="color:var(--ink3);font-size:.82rem">Mindestens 4 Tage erfassen, dann zeigen wir dir Ausreißer.</p>';
  }
}

