};

function getPageSubtitle(page) {
  if (page === 'dashboard') {
    const s = state.settings;
    const parts = [];
    if (s.name) parts.push(s.name);
    if (s.kueche) parts.push(s.kueche);
    if (s.stadt) parts.push(s.stadt);
    return parts.length ? parts.join(' · ') : 'Ihr Restaurant auf einen Blick';
  }
  return (pageTitles[page] || [page,''])[1];
}

function toggleCat(cat) {
  const el = document.getElementById('cat-'+cat);
  if(el.classList.contains('open')) {
    el.classList.remove('open');
  } else {
    // Close all categories, open this one
    document.querySelectorAll('.nav-cat').forEach(c => c.classList.remove('open'));
    el.classList.add('open');
  }
}

function navigateSub(cat, page) {
  // Open the category
  if(cat) {
    document.querySelectorAll('.nav-cat').forEach(c => c.classList.remove('open'));
    document.getElementById('cat-'+cat).classList.add('open');
  }
  // Activate the sub-item
  document.querySelectorAll('.nav-sub-item').forEach(n => n.classList.remove('active'));
  document.querySelectorAll('.nav-util-item').forEach(n => n.style.color = '');
  const navEl = document.getElementById('nav-'+page);
  if(navEl) {
    if(navEl.classList.contains('nav-sub-item')) navEl.classList.add('active');
    else navEl.style.color = 'rgba(255,255,255,.9)';
  }
  // Show the page
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');
  // Update topbar
  const pt = pageTitles[page] || [page,''];
  document.getElementById('topbar-title').textContent = pt[0];
  document.getElementById('topbar-sub').textContent = getPageSubtitle(page);
  refreshPage(page);
