async function saveFixkosten() {
  const betrag = parseFloat(document.getElementById('fk-betrag').value)||0;
  const monat  = document.getElementById('fk-monat').value;
  if(!monat || !betrag) { toast('Betrag und Monat sind erforderlich'); return; }
  const artInput = document.getElementById('fk-art-input');
  const art = artInput ? artInput.value.trim() : (document.getElementById('fk-art')?.value || 'Sonstiges');
  if(!art) { toast('Kostenkategorie eingeben'); return; }
  const beschreibung = document.getElementById('fk-beschreibung')?.value || '';
  const jaehrlich = document.getElementById('fk-jaehrlich')?.checked || false;
  const payload = { art, betrag, monat, typ:document.getElementById('fk-typ').value, beschreibung, jaehrlich };
  if(!DEMO_MODE && db && currentUser) {
    const { data, error } = await db.from('fixkosten').insert({ ...payload, user_id: currentUser.id }).select().single();
    if(error) { toast('Fehler: '+error.message); return; }
    state.fixkosten.push(remapFixkosten(data));
  } else {
    state.fixkosten.push({ id:uid(), ...payload }); save();
  }
  closeModal('modal-fixkosten'); renderFixkosten(); toast('Fixkosten gespeichert');
}

async function deleteFixkosten(id) {
  if(!confirm('Diesen Eintrag wirklich löschen?')) return;
  if(!DEMO_MODE && db) await db.from('fixkosten').delete().eq('id', id);
  state.fixkosten = state.fixkosten.filter(f=>f.id!==id); save(); renderFixkosten(); toast('Eintrag gelöscht');
}

