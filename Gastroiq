function getShiftTypes() {
  const vorlagen = (state.schichtvorlagen || []);
  if(vorlagen.length === 0) return {...DEFAULT_SHIFT_TYPES};
  const types = {...DEFAULT_SHIFT_TYPES};
  vorlagen.forEach(v => {
    types['v_'+v.id] = { label:v.label, color:v.color||'#f1f5f9', textColor:v.textColor||'#334155', start:v.start, end:v.end, hours:calcHoursFromTimes(v.start, v.end) };
  });
  return types;
}

function calcHoursFromTimes(start, end) {
  if(!start || !end) return 0;
  let [sh,sm]=start.split(':').map(Number), [eh,em]=end.split(':').map(Number);
  let diff=(eh*60+em)-(sh*60+sm);
  if(diff<0) diff+=1440;
  return Math.round(diff/60*10)/10;
}

