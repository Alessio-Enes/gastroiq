async function saveGericht() {
  const name = document.getElementById('g-name').value;
  if(!name) { toast('Name erforderlich'); return; }
  const payload = { name, kategorie:document.getElementById('g-kat').value, typ:document.getElementById('g-typ').value, vk_preis:parseFloat(document.getElementById('g-vk').value)||0, wareneinsatz:parseFloat(document.getElementById('g-we').value)||0, togo:document.getElementById('g-togo').value==='1', beliebtheit:parseInt(document.getElementById('g-pop').value)||3 };
  if(!DEMO_MODE && db && currentUser) {
    const { data, error } = await db.from('gerichte').insert({ ...payload, user_id: currentUser.id }).select().single();
    if(error) { toast('Fehler: '+error.message); return; }
    state.gerichte.push(remapGericht(data));
  } else {
    state.gerichte.push({ id:uid(), name:payload.name, kategorie:payload.kategorie, typ:payload.typ, vkPreis:payload.vk_preis, wareneinsatz:payload.wareneinsatz, togo:payload.togo?1:0, beliebtheit:payload.beliebtheit });
    save();
  }
  closeModal('modal-gericht'); renderSpeisekarte(); toast('✓ Gericht gespeichert');
}

function renderSpeisekarte() {
  const g = state.gerichte;
  document.getElementById('sk-anzahl').textContent = g.length;
  document.getElementById('sk-vegan').textContent = g.filter(x=>x.typ==='vegan'||x.typ==='vegetarisch').length;
  const avgFc = g.length>0 ? g.reduce((s,x)=>s+(x.vkPreis>0?(x.wareneinsatz/x.vkPreis*100):0),0)/g.length : 0;
  const avgDb = g.length>0 ? g.reduce((s,x)=>s+(x.vkPreis-x.wareneinsatz),0)/g.length : 0;
  document.getElementById('sk-avgfc').textContent = fmtPct(avgFc);
  document.getElementById('sk-avgdb').textContent = fmtEur(avgDb);

  const typLabels = {fleisch:'🥩 Fleisch',fisch:'🐟 Fisch',vegetarisch:'🥗 Vegetarisch',vegan:'🌱 Vegan'};
  // Sort by profitability (DB descending)
  const sorted = [...g].sort((a,b)=>(b.vkPreis-b.wareneinsatz)-(a.vkPreis-a.wareneinsatz));
  const maxDB = sorted.length>0 ? Math.max(...sorted.map(x=>x.vkPreis-x.wareneinsatz)) : 1;

  document.getElementById('speisekarte-tbody').innerHTML = sorted.map((x,rank)=>{
    const fc = x.vkPreis>0?(x.wareneinsatz/x.vkPreis*100):0;
    const db = x.vkPreis - x.wareneinsatz;
    const dbMarge = x.vkPreis>0?(db/x.vkPreis*100):0;
    const fcClass = fc>32?'badge-red':fc>28?'badge-yellow':'badge-green';
    const dbClass = dbMarge>65?'badge-green':dbMarge>50?'badge-yellow':'badge-red';
    // Net profit indicator
    const profitColor = db>=0 ? 'var(--green)' : 'var(--red)';
    const profitIcon = db>=3 ? '🟢' : db>=0 ? '🟡' : '🔴';
    const profitLabel = db>=3 ? 'Profitabel' : db>=0 ? 'Break-even' : 'Verlust';
    // Profit bar width
    const barW = maxDB > 0 ? Math.max(0, Math.min(100, (db/maxDB)*100)) : 0;
    return `<tr>
      <td>
        <div style="font-weight:700;font-size:.85rem">${x.name}</div>
        <div style="margin-top:.25rem;height:5px;background:var(--border);border-radius:3px;width:120px">
          <div style="height:5px;border-radius:3px;background:${profitColor};width:${barW}%"></div>
        </div>
      </td>
      <td>${x.kategorie}</td>
      <td><span class="badge badge-blue">${typLabels[x.typ]||x.typ}</span></td>
      <td>${fmtEur(x.vkPreis)}</td>
      <td>${fmtEur(x.wareneinsatz)}</td>
      <td><span class="badge ${fcClass}">${fmtPct(fc)}<span style="font-weight:400;font-size:.68rem"> = ${fmtEur(x.wareneinsatz)} Kosten</span></span></td>
      <td><span style="font-weight:800;color:${profitColor}">${fmtEur(db)}</span></td>
      <td><span class="badge ${dbClass}">${fmtPct(dbMarge)}<span style="font-weight:400;font-size:.68rem"> Marge</span></span></td>
      <td><span title="${profitLabel}">${profitIcon} ${profitLabel}</span></td>
      <td>${'⭐'.repeat(x.beliebtheit||1)}</td>
      <td><button class="btn btn-sm btn-danger" onclick="deleteGericht('${x.id}')">✕</button></td>
    </tr>`;
  }).join('');

  destroyChart('chart-db-gerichte');
  const ctx = document.getElementById('chart-db-gerichte');
  if(ctx && g.length>0) dashCharts['chart-db-gerichte'] = new Chart(ctx,{
    type:'bar', data:{ labels:g.map(x=>x.name), datasets:[
      { label:'Verdienst (€)', data:g.map(x=>x.vkPreis-x.wareneinsatz), backgroundColor:'#16a34a', yAxisID:'y' },
      { label:'Wareneinsatz %', data:g.map(x=>x.vkPreis>0?x.wareneinsatz/x.vkPreis*100:0), backgroundColor:'rgba(234,88,12,.3)', type:'line', yAxisID:'y2', tension:.3 }
    ]}, options:{ ...chartOpts(), scales:{ y:{position:'left'}, y2:{position:'right',grid:{drawOnChartArea:false}} }, plugins:{legend:{display:true}} }
  });
}

async function deleteGericht(id) {
  if(!DEMO_MODE && db) await db.from('gerichte').delete().eq('id', id);
  state.gerichte = state.gerichte.filter(g=>g.id!==id); save(); renderSpeisekarte();
}

