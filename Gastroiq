const nachfrageIndex = {0:72,1:68,2:74,3:80,4:88,5:98,6:95};

function initPreisempfehlung() {
  const now = new Date();
  const days = ['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'];
  const idx = nachfrageIndex[now.getDay()];
  document.getElementById('pe-tag').textContent = days[now.getDay()];
  document.getElementById('pe-index').textContent = idx+'/100';

  const m = getCurrentMonth(); const d = getMonthData(m);
  const potenzial = d.umsatz/Math.max(1,d.tageCount)*(idx/80)-d.umsatz/Math.max(1,d.tageCount);
  document.getElementById('pe-potenzial').textContent = (potenzial>0?'+':'')+fmtEur(potenzial);
  document.getElementById('pe-empfehlung').textContent = idx>=90?'Preise erhöhen':idx>=75?'Preise halten':'Angebot/Aktion';

  const tbody = document.getElementById('preis-tbody');
  if(state.gerichte.length===0) { tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--ink3)">Erst Gerichte anlegen</td></tr>'; return; }

  tbody.innerHTML = state.gerichte.map(g=>{
    const fc = g.vkPreis>0?g.wareneinsatz/g.vkPreis:0;
    let delta=0, grund='';
    if(idx>=90&&fc<0.28){delta=Math.round(g.vkPreis*0.08*2)/2;grund='Viel Nachfrage + gute Marge';}
    else if(idx>=80&&g.beliebtheit>=4){delta=0.50;grund='Beliebt + starker Tag';}
    else if(idx<75&&fc>0.30){delta=-0.50;grund='Ruhiger Tag – mehr Gäste locken';}
    else{delta=0;grund='Passt so';}
    const neu=Math.round((g.vkPreis+delta)*2)/2;
    const cls=delta>0?'badge-green':delta<0?'badge-red':'badge-blue';
    return `<tr><td class="td-bold">${g.name}</td><td>${fmtEur(g.vkPreis)}</td>
      <td style="font-weight:700;color:var(--${delta>0?'green':delta<0?'red':'ink'})">${fmtEur(neu)}</td>
      <td><span class="badge ${cls}">${delta>0?'+':''}${fmtEur(delta)}</span></td>
      <td style="font-size:.78rem;color:var(--ink3)">${grund}</td></tr>`;
  }).join('');

  const faktoren = [
    {icon:'📅',label:'Wochentag',val:days[now.getDay()],score:idx},
    {icon:'📊',label:'Nachfrage',val:idx+'/100',score:idx},
    {icon:'🎯',label:'Gäste-Ziel',val:state.settings.gasteZiel+' /Tag',score:80},
    {icon:'💶',label:'Ø Bon aktuell',val:fmtEur(d.avgBon),score:d.avgBon>=(state.settings.bonZiel||22)?85:60},
  ];
  document.getElementById('nachfrage-faktoren').innerHTML = faktoren.map(f=>`
    <div style="display:flex;justify-content:space-between;align-items:center;padding:.6rem 0;border-bottom:1px solid var(--border)">
      <span style="font-size:.82rem">${f.icon} ${f.label}</span>
      <div style="text-align:right">
        <div style="font-size:.82rem;font-weight:700">${f.val}</div>
        <div class="progress-bar" style="width:80px;margin-top:.2rem"><div class="progress-fill" style="width:${f.score}%;background:${f.score>=80?'var(--green)':f.score>=60?'var(--yellow)':'var(--red)'}"></div></div>
      </div>
    </div>`).join('');
}

