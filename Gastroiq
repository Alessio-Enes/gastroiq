}

function openNewMitarbeiter() {
  editingMaId = null;
  document.getElementById('ma-modal-title').textContent = '👤 Mitarbeiter hinzufügen';
  document.getElementById('m-name').value = '';
  document.getElementById('m-rolle').value = 'Küche';
  document.getElementById('m-lohn').value = '13.50';
  document.getElementById('m-std').value = '80';
  document.getElementById('m-wunschfrei').value = '';
  document.querySelectorAll('.m-verfueg-cb').forEach(cb => {
    cb.checked = ['Mo','Di','Mi','Do','Fr'].includes(cb.value);
  });
  document.getElementById('ma-delete-btn').style.display = 'none';
  openModal('modal-mitarbeiter');
}

function deleteMitarbeiterEdit() {
  if(!editingMaId) return;
  if(!confirm('Mitarbeiter wirklich löschen?')) return;
  deletePersonal(editingMaId);
  closeModal('modal-mitarbeiter');
}

async function saveMitarbeiter() {
  const name = document.getElementById('m-name').value.trim();
  if(!name) { toast('Name erforderlich'); return; }
  const verfueg = Array.from(document.querySelectorAll('.m-verfueg-cb:checked')).map(cb => cb.value);
  const wunschfrei = document.getElementById('m-wunschfrei').value.split(',').map(s => s.trim()).filter(Boolean);
  const payload = { name, rolle: document.getElementById('m-rolle').value, lohn: parseFloat(document.getElementById('m-lohn').value)||0, stunden: parseFloat(document.getElementById('m-std').value)||0 };

  if(editingMaId) {
    // UPDATE existing
    const idx = state.personal.findIndex(p => p.id === editingMaId);
    if(idx > -1) {
      state.personal[idx] = { ...state.personal[idx], ...payload, verfueg, wunschfrei };
      save();
      closeModal('modal-mitarbeiter');
      renderPersonal();
      if(document.getElementById('page-schichtplan').classList.contains('active')) renderSchichtplan();
      toast('✓ Mitarbeiter aktualisiert');
    }
    editingMaId = null;
    return;
  }

  // CREATE new
  if(!DEMO_MODE && db && currentUser) {
    const { data, error } = await db.from('personal').insert({ ...payload, user_id: currentUser.id }).select().single();
    if(error) { toast('Fehler: '+error.message); return; }
    const p = remapPersonal(data);
    p.verfueg = verfueg;
    p.wunschfrei = wunschfrei;
    state.personal.push(p);
  } else {
    state.personal.push({ id: uid(), ...payload, verfueg, wunschfrei }); save();
  }
  closeModal('modal-mitarbeiter'); renderPersonal(); toast('✓ Mitarbeiter gespeichert');
}

function renderPersonal() {
  const d = getMonthData(getCurrentMonth());
  document.getElementById('p-anzahl').textContent = state.personal.length;
  document.getElementById('p-gesamt').textContent = fmtEur(d.personalGesamt);
  document.getElementById('p-stunden').textContent = state.personal.reduce((s,m)=>s+(m.stunden||0),0)+' h';
  document.getElementById('p-quote').textContent = fmtPct(d.personalPct);
  const pqAbs = document.getElementById('p-quote-abs');
  if(pqAbs) pqAbs.textContent = 'Von 100 € Umsatz → '+fmt(d.personalPct,0)+' € an dein Team';

  document.getElementById('personal-tbody').innerHTML = state.personal.map(m=>{
    const kosten = (m.lohn||0)*(m.stunden||0);
    const verf = (m.verfueg||DAY_NAMES).join(', ');
    const wf = (m.wunschfrei||[]).join(', ') || '–';
    return `<tr>
      <td class="td-bold">${m.name}</td><td>${m.rolle}</td><td>${m.stunden} h</td><td>${fmtEur(m.lohn)}</td><td class="td-bold">${fmtEur(kosten)}</td>
      <td style="font-size:.72rem;color:var(--ink3)">${verf}</td>
      <td>
        <button class="btn btn-sm btn-outline btn-edit" onclick="openEditMitarbeiter('${m.id}')">✏️ Edit</button>
        <button class="btn btn-sm btn-danger" onclick="deletePersonal('${m.id}')" style="margin-left:.3rem">✕</button>
      </td></tr>`;
  }).join('');

  destroyChart('chart-personal');
  const ctx = document.getElementById('chart-personal');
  if(ctx && state.personal.length>0) dashCharts['chart-personal'] = new Chart(ctx,{
    type:'doughnut', data:{ labels:state.personal.map(m=>m.name), datasets:[{ data:state.personal.map(m=>(m.lohn||0)*(m.stunden||0)), backgroundColor:['#1a56db','#0d9265','#d95f0a','#6d28d9','#a16207','#c0261d'], borderWidth:2, borderColor:'#fff' }]},
    options:{...pieChartOpts('bottom')}
  });
}

async function deletePersonal(id) {
  if(!DEMO_MODE && db) await db.from('personal').delete().eq('id', id);
  state.personal = state.personal.filter(m=>m.id!==id); save(); renderPersonal();
}

