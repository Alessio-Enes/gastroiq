// ── DATE PARSING ─────────────────────────────────────────────
function csvParseDate(raw) {
  if (!raw) return null;
  raw = raw.trim().replace(/["']/g, '');

  // ISO: 2025-11-01
  if (/^\d{4}-\d{2}-\d{2}/.test(raw)) return raw.substring(0, 10);

  // German: 01.11.2025 or 1.11.2025
  const de = raw.match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})/);
  if (de) return `${de[3]}-${de[2].padStart(2,'0')}-${de[1].padStart(2,'0')}`;

  // US: 11/01/2025 or Nov 1, 2025
  const us = raw.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})/);
  if (us) return `${us[3]}-${us[1].padStart(2,'0')}-${us[2].padStart(2,'0')}`;

  // Month name: Nov 1, 2025 or 1. November 2025
  const months = {jan:1,feb:2,mar:3,mär:3,apr:4,may:5,mai:5,jun:6,jul:7,aug:8,sep:9,oct:10,okt:10,nov:11,dec:12,dez:12};
  const mn = raw.match(/(\d{1,2})[\s.]*([a-zA-Züäö]+)[\s.,]*(\d{4})/i) ||
             raw.match(/([a-zA-Züäö]+)[\s.,]*(\d{1,2})[\s.,]*(\d{4})/i);
  if (mn) {
    const mStr = (mn[2] || mn[1]).substring(0, 3).toLowerCase();
    const m = months[mStr];
    if (m) {
      const d = parseInt(mn[1]) || parseInt(mn[2]);
      const y = parseInt(mn[3]);
      return `${y}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    }
  }
  return null;
}

function csvParseNum(raw) {
  if (!raw && raw !== 0) return null;
  const s = String(raw).trim().replace(/[€$£\s]/g,'').replace(/[^\d.,-]/g,'');
  // European: 1.234,56 → 1234.56
  if (/\d{1,3}\.\d{3},\d{2}$/.test(s)) return parseFloat(s.replace(/\./g,'').replace(',','.'));
  // German decimal: 1234,56
  if (/,\d{1,2}$/.test(s)) return parseFloat(s.replace(/\./g,'').replace(',','.'));
  return parseFloat(s.replace(',','')) || 0;
}

// ── CONFLICT DETECTION ───────────────────────────────────────
function csvAnalyzeConflicts() {
  const { rows, headers, colMap } = csvState;
  const existingByDate = {};
  state.tageseintraege.forEach(t => existingByDate[t.datum] = t);

  csvState.conflicts = [];
  csvState.newRows = [];

  rows.forEach(row => {
    const get = (field) => {
      const h = colMap[field];
      if (!h) return null;
      const idx = headers.indexOf(h);
      return idx >= 0 ? row[idx] : null;
    };

    const datum = csvParseDate(get('datum'));
    if (!datum) return; // skip unparseable dates

    const incoming = {
      datum,
      umsatz:     Math.round((csvParseNum(get('umsatz')) || 0) * 100) / 100,
      gaeste:     Math.round(csvParseNum(get('gaeste')) || 0),
      togo:       Math.round((csvParseNum(get('togo')) || 0) * 100) / 100,
      getraenke:  Math.round((csvParseNum(get('getraenke')) || 0) * 100) / 100,
      topGericht: get('topGericht') || '',
      notiz:      get('notiz') || '',
      source:     'import:csv',
    };

    if (existingByDate[datum]) {
      csvState.conflicts.push({
        datum,
        existing: existingByDate[datum],
        incoming,
        resolution: existingByDate[datum].source && existingByDate[datum].source.startsWith('import')
          ? 'overwrite'   // imported data: default overwrite with newer import
          : 'keep',       // manually entered: default keep (protect manual work)
      });
    } else {
      csvState.newRows.push(incoming);
    }
  });
}

function csvRenderConflicts() {
  const total = csvState.rows.length;
  const nConf = csvState.conflicts.length;
  const nNew = csvState.newRows.length;

  document.getElementById('conflict-headline').textContent =
    `${nConf} Datums-Konflikte gefunden`;
  document.getElementById('conflict-sub').textContent =
    `${nNew} neue Einträge · ${nConf} Überschneidungen mit vorhandenen Daten · Manuelle Einträge sind standardmäßig geschützt`;

  const tb = document.getElementById('conflict-tbody');
  tb.innerHTML = csvState.conflicts.map((c, i) => {
    const src = c.existing.source || 'manual';
    const srcLabel = src.startsWith('import') ? src.replace('import:','') : 'manuell';
    const srcColor = src === 'manual' ? 'var(--green)' : 'var(--ink3)';
    const uDiff = c.incoming.umsatz - c.existing.umsatz;
    const uDiffStr = uDiff >= 0 ? `<span class="cfl-diff-up">+${fmtEur(uDiff)}</span>` : `<span class="cfl-diff-dn">${fmtEur(uDiff)}</span>`;

    const res = c.resolution;
    return `<tr id="cfl-row-${i}" class="${res==='keep'?'will-skip':''}">
      <td><strong>${c.datum}</strong></td>
      <td class="cfl-old">${fmtEur(c.existing.umsatz)}</td>
      <td class="cfl-new">${fmtEur(c.incoming.umsatz)} ${uDiffStr}</td>
      <td class="cfl-old">${c.existing.gaeste || '–'}</td>
      <td class="cfl-new">${c.incoming.gaeste || '–'}</td>
      <td><span style="font-size:.7rem;font-weight:700;color:${srcColor}">${srcLabel}</span></td>
      <td>
        <div style="display:flex;gap:4px">
          <button class="resolve-btn ${res==='keep'?'keep':''}" onclick="csvSetResolution(${i},'keep')" title="Bestehenden Eintrag behalten, Import überspringen">Behalten</button>
          <button class="resolve-btn ${res==='overwrite'?'overwrite':''}" onclick="csvSetResolution(${i},'overwrite')" title="Import überschreibt bestehenden Eintrag">Ersetzen</button>
          <button class="resolve-btn ${res==='merge'?'merge':''}" onclick="csvSetResolution(${i},'merge')" title="Umsatz und Gäste werden gemittelt">Mitteln</button>
        </div>
      </td>
    </tr>`;
  }).join('');
}

function csvSetResolution(i, res) {
  csvState.conflicts[i].resolution = res;
  const row = document.getElementById('cfl-row-' + i);
  if (row) {
    row.className = res === 'keep' ? 'will-skip' : '';
    // Refresh buttons
    ['keep','overwrite','merge'].forEach(r => {
      const btns = row.querySelectorAll('.resolve-btn');
      btns.forEach(b => {
        if (b.textContent.trim().toLowerCase().startsWith(r === 'keep' ? 'beh' : r === 'overwrite' ? 'ers' : 'mit')) {
          b.className = 'resolve-btn' + (r === res ? ' ' + r : '');
        }
      });
    });
  }
}

function csvBulkResolve(res) {
  csvState.conflicts.forEach((c, i) => {
    c.resolution = res;
    const row = document.getElementById('cfl-row-' + i);
    if (row) row.className = res === 'keep' ? 'will-skip' : '';
  });
  csvRenderConflicts(); // re-render to update button states
}

// ── APPLY IMPORT ─────────────────────────────────────────────
function csvApplyImport() {
  const now = new Date().toISOString();
  let imported = 0, skipped = 0, overwritten = 0, merged = 0;

  // Handle new rows
  csvState.newRows.forEach(row => {
    row.id = uid();
    state.tageseintraege.push(row);
    imported++;
  });

  // Handle conflicts
  csvState.conflicts.forEach(c => {
    if (c.resolution === 'keep') {
      skipped++;
    } else if (c.resolution === 'overwrite') {
      const idx = state.tageseintraege.findIndex(t => t.datum === c.datum);
      if (idx >= 0) {
        state.tageseintraege[idx] = { ...c.incoming, id: state.tageseintraege[idx].id };
        overwritten++;
      }
    } else if (c.resolution === 'merge') {
      const idx = state.tageseintraege.findIndex(t => t.datum === c.datum);
      if (idx >= 0) {
        const ex = state.tageseintraege[idx];
        state.tageseintraege[idx] = {
          ...ex,
          umsatz: Math.round(((ex.umsatz + c.incoming.umsatz) / 2) * 100) / 100,
          gaeste: Math.round((ex.gaeste + c.incoming.gaeste) / 2),
          togo: ex.togo && c.incoming.togo ? Math.round(((ex.togo + c.incoming.togo) / 2) * 100) / 100 : (ex.togo || c.incoming.togo || 0),
          source: 'merged',
        };
        merged++;
      }
    }
  });

  // Sort by date
  state.tageseintraege.sort((a,b) => a.datum.localeCompare(b.datum));

  // Log the import
  const allDates = [...csvState.newRows, ...csvState.conflicts.filter(c => c.resolution !== 'keep')].map(x => x.datum || x.incoming?.datum).filter(Boolean).sort();
  const logEntry = {
    id: uid(),
    ts: now,
    fileName: csvState.fileName,
    system: 'csv',
    rows: imported + overwritten + merged,
    newRows: imported,
    overwritten,
    merged,
    skipped,
    totalRows: csvState.rows.length,
    dateFrom: allDates[0] || '',
    dateTo: allDates[allDates.length - 1] || '',
    colMap: { ...csvState.colMap },
  };
  if (!state.importLog) state.importLog = [];
  state.importLog.unshift(logEntry);

  save();
  renderDashboard();

  return { imported, skipped, overwritten, merged };
}

// ── POS CONFLICT DETECTION ────────────────────────────────────
function csvAnalyzeConflictsPOS() {
  const aggregated = csvState._posResult?.aggregated || [];
  const existingByDate = {};
  state.tageseintraege.forEach(t => existingByDate[t.datum] = t);

  csvState.conflicts = [];
  csvState.newRows = [];

  aggregated.forEach(incoming => {
    if (existingByDate[incoming.datum]) {
      csvState.conflicts.push({
        datum: incoming.datum,
        existing: existingByDate[incoming.datum],
        incoming,
        resolution: existingByDate[incoming.datum].source?.startsWith('import') ? 'overwrite' : 'keep',
      });
    } else {
      csvState.newRows.push(incoming);
    }
  });
}

// ── POS APPLY IMPORT ─────────────────────────────────────────
function csvApplyImportPOS() {
  const now = new Date().toISOString();
  let imported = 0, skipped = 0, overwritten = 0, merged = 0;

  csvState.newRows.forEach(row => {
    row.id = uid();
    state.tageseintraege.push(row);
    imported++;
  });

  csvState.conflicts.forEach(c => {
    if (c.resolution === 'keep') {
      skipped++;
    } else if (c.resolution === 'overwrite') {
      const idx = state.tageseintraege.findIndex(t => t.datum === c.datum);
      if (idx >= 0) {
        state.tageseintraege[idx] = { ...c.incoming, id: state.tageseintraege[idx].id };
        overwritten++;
      }
    } else if (c.resolution === 'merge') {
      const idx = state.tageseintraege.findIndex(t => t.datum === c.datum);
      if (idx >= 0) {
        const ex = state.tageseintraege[idx];
        state.tageseintraege[idx] = {
          ...ex,
          umsatz: Math.round(((ex.umsatz + c.incoming.umsatz) / 2) * 100) / 100,
          gaeste: Math.round((ex.gaeste + c.incoming.gaeste) / 2),
          getraenke: Math.round(((ex.getraenke||0) + c.incoming.getraenke) / 2 * 100) / 100,
          _wareneinsatzFehlt: true,
          source: 'merged:pos',
        };
        merged++;
      }
    }
  });

  state.tageseintraege.sort((a,b) => a.datum.localeCompare(b.datum));

  // Log
  const allDates = [...csvState.newRows, ...csvState.conflicts.filter(c=>c.resolution!=='keep').map(c=>c.incoming)].map(r=>r.datum).filter(Boolean).sort();
  const logEntry = {
    id: uid(), ts: now, fileName: csvState.fileName, system: 'csv-pos',
    rows: imported + overwritten + merged, newRows: imported, overwritten, merged, skipped,
    totalRows: csvState._posResult?.totalInputRows || 0,
    dateFrom: allDates[0] || '', dateTo: allDates[allDates.length-1] || '',
    colMap: { mode: 'POS-Aggregation' },
    _wareneinsatzFehlt: imported + overwritten + merged,
  };
  if (!state.importLog) state.importLog = [];
  state.importLog.unshift(logEntry);

  save();
  renderDashboard();
  return { imported, skipped, overwritten, merged, posMode: true };
}

