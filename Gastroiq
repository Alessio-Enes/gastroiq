let mhChartType = 'bar';

function toggleMhChart(type) {
  mhChartType = type;
  document.getElementById('mh-btn-bar').style.fontWeight = type === 'bar' ? '800' : '500';
  document.getElementById('mh-btn-line').style.fontWeight = type === 'line' ? '800' : '500';
  renderMonatshistorie();
}

function getAllMonths() {
  const months = new Set();
  state.tageseintraege.forEach(t => { if(t.datum) months.add(t.datum.substr(0,7)); });
  // Also include demo months
  ['2025-06','2025-07','2025-08','2025-09','2025-10','2025-11'].forEach(m => months.add(m));
  return Array.from(months).sort();
}

function fmtMonthLabel(m) {
  const [y,mo] = m.split('-');
  const names = ['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'];
  return names[parseInt(mo)-1] + ' ' + y.substr(2);
}

function renderMonatshistorie() {
  const metricSel = document.getElementById('mh-metric');
  const metric = metricSel ? metricSel.value : 'umsatz';
  const months = getAllMonths().slice(-12); // last 12 months max
  const labels = months.map(fmtMonthLabel);
  const metricFmt = {
    umsatz: v => fmtEur(v),
    ebit: v => fmtEur(v),
    db: v => fmtEur(v),
    foodCostPct: v => fmtPct(v),
    personalPct: v => fmtPct(v),
    avgBon: v => fmtEur(v),
    gaeste: v => Math.round(v).toLocaleString('de-DE')
  };
  const fmt = metricFmt[metric] || (v => v);

  const data = months.map(m => {
    const d = getMonthData(m);
    return d[metric] || 0;
  });

  // Outlier detection (>1.5 std dev from mean)
  const nonZero = data.filter(v => v !== 0);
  const avg = nonZero.length > 0 ? nonZero.reduce((s,v)=>s+v,0)/nonZero.length : 0;
  const std = nonZero.length > 1 ? Math.sqrt(nonZero.map(v=>Math.pow(v-avg,2)).reduce((s,v)=>s+v,0)/nonZero.length) : 0;
  const isOutlier = data.map(v => std > 0 && Math.abs(v-avg) > 1.4*std && v !== 0);

  // KPIs
  const withData = data.filter(v => v !== 0);
  if(withData.length > 0) {
    const best = Math.max(...withData), worst = Math.min(...withData);
    const bestIdx = data.indexOf(best), worstIdx = data.indexOf(worst);
    document.getElementById('mh-best-val').textContent = fmt(best);
    document.getElementById('mh-best-label').textContent = labels[bestIdx];
    document.getElementById('mh-worst-val').textContent = fmt(worst);
    document.getElementById('mh-worst-label').textContent = labels[worstIdx];
    document.getElementById('mh-avg-val').textContent = fmt(avg);

    // Trend: last 3 months vs prior 3 months
    if(withData.length >= 4) {
      const last3 = withData.slice(-3).reduce((s,v)=>s+v,0)/3;
      const prev3 = withData.slice(-6,-3).reduce((s,v)=>s+v,0)/Math.max(1,withData.slice(-6,-3).length);
      const trendPct = prev3 > 0 ? ((last3-prev3)/prev3*100) : 0;
      const trendEl = document.getElementById('mh-trend-val');
      const trendLbl = document.getElementById('mh-trend-label');
      trendEl.textContent = (trendPct >= 0 ? '▲ +' : '▼ ') + trendPct.toFixed(1) + '%';
      trendEl.style.color = trendPct >= 0 ? 'var(--green)' : 'var(--red)';
      trendLbl.textContent = trendPct >= 0 ? 'Aufwärtstrend' : 'Abwärtstrend';
    }
  }

  // Outlier badges
  const badges = document.getElementById('mh-ausreisser-badges');
  if(badges) {
    badges.innerHTML = isOutlier.map((out, i) => {
      if(!out || data[i] === 0) return '';
      const dev = ((data[i]-avg)/avg*100);
      return `<span class="badge ${dev>0?'badge-green':'badge-red'}" style="font-size:.72rem">
        ⚡ ${labels[i]}: ${dev>0?'+':''}${dev.toFixed(0)}% vs. Ø
      </span>`;
    }).join('');
  }

  // Chart
  const colors = data.map((v, i) => {
    if(v === 0) return 'rgba(200,200,200,.3)';
    if(isOutlier[i]) {
      const dev = v - avg;
      return dev > 0 ? 'rgba(22,163,74,.85)' : 'rgba(220,38,38,.85)';
    }
    return 'rgba(37,99,235,.65)';
  });
  const borderColors = colors.map(c => c.replace(/[\d.]+\)$/, '1)'));

  destroyChart('chart-monatshistorie');
  const ctx = document.getElementById('chart-monatshistorie');
  if(!ctx) return;
  dashCharts['chart-monatshistorie'] = new Chart(ctx, {
    type: mhChartType,
    data: {
      labels,
      datasets: [{
        label: metricSel?.options[metricSel.selectedIndex]?.text || metric,
        data,
        backgroundColor: mhChartType === 'line' ? 'rgba(37,99,235,.08)' : colors,
        borderColor: mhChartType === 'line' ? '#2563eb' : borderColors,
        borderWidth: 2,
        tension: .4,
        fill: mhChartType === 'line',
        pointBackgroundColor: data.map((v,i) => isOutlier[i] && v !== avg ? (v>avg?'#16a34a':'#dc2626') : '#2563eb'),
        pointRadius: data.map((v,i) => isOutlier[i] ? 7 : 4),
        pointHoverRadius: 8
      }]
    },
    options: {
      ...chartOpts(),
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => {
              const v = ctx.raw;
              const dev = avg > 0 ? ((v-avg)/avg*100) : 0;
              const tag = isOutlier[ctx.dataIndex] ? ` (${dev>0?'+':''}${dev.toFixed(0)}% vs. Ø)` : '';
              return fmt(v) + tag;
            }
          }
        }
      }
    }
  });

  // Tabelle
  const tbody = document.getElementById('mh-table-body');
  if(!tbody) return;
  tbody.innerHTML = months.map((m,i) => {
    const d = getMonthData(m);
    const ebitColor = d.ebit >= 0 ? 'var(--green)' : 'var(--red)';
    const ebitPct = d.umsatz > 0 ? (d.ebit/d.umsatz*100) : 0;
    const statusBadge = d.umsatz === 0 ? '<span class="badge">Keine Daten</span>' :
      d.ebit > 0 ? '<span class="badge badge-green">✅ Gewinn</span>' :
      d.ebit < -200 ? '<span class="badge badge-red">🔴 Verlust</span>' :
      '<span class="badge badge-yellow">⚠️ Break-even</span>';
    const highlight = isOutlier[i] && d.umsatz > 0 ? 'background:rgba(251,191,36,.08)' : '';
    return `<tr style="${highlight}">
      <td style="font-weight:700">${fmtMonthLabel(m)} ${isOutlier[i]&&d.umsatz>0?'⚡':''}</td>
      <td>${fmtEur(d.umsatz)}</td>
      <td style="font-weight:700;color:${ebitColor}">${fmtEur(d.ebit)}</td>
      <td><span class="badge ${d.ebit>=0?'badge-green':'badge-red'}">${fmtPct(Math.abs(ebitPct))}</span></td>
      <td><span class="badge ${d.foodCostPct>(state.settings.fcZiel||28)?'badge-red':'badge-green'}">${fmtPct(d.foodCostPct)}</span></td>
      <td><span class="badge ${d.personalPct>(state.settings.pkZiel||33)?'badge-red':'badge-green'}">${fmtPct(d.personalPct)}</span></td>
      <td>${fmtEur(d.avgBon)}</td>
      <td>${d.gaeste.toLocaleString('de-DE')}</td>
      <td>${statusBadge}</td>
    </tr>`;
  }).reverse().join('');
}

