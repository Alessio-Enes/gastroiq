// ════════════════════════════════════════════════════
// CALCULATIONS
// ════════════════════════════════════════════════════
function getMonthData(month) {
  const te = state.tageseintraege.filter(t=>monthStr(t.datum)===month);
  const fk = state.fixkosten.filter(f=>f.monat===month);
  const vb = state.verbrauch.filter(v=>monthStr(v.datum)===month);
  const umsatz = te.reduce((s,t)=>s+(t.umsatz||0),0);
  const gaeste = te.reduce((s,t)=>s+(t.gaeste||0),0);
  const togo = te.reduce((s,t)=>s+(t.togo||0),0);
  const fixkostenGesamt = fk.reduce((s,f)=>s+(f.betrag||0),0);
  const personalGesamt = state.personal.reduce((s,m)=>s+(m.lohn||0)*(m.stunden||0),0);
  const einkaufGesamt = vb.reduce((s,v)=>s+(v.einkauf||0),0);
  const foodCostPct = umsatz>0 ? (einkaufGesamt/umsatz)*100 : 0;
  const personalPct = umsatz>0 ? (personalGesamt/umsatz)*100 : 0;
  const fixPct = umsatz>0 ? (fixkostenGesamt/umsatz)*100 : 0;
  const avgBon = gaeste>0 ? umsatz/gaeste : 0;
  const db = umsatz - einkaufGesamt;
  const ebit = umsatz - einkaufGesamt - personalGesamt - fixkostenGesamt;
  return { umsatz,gaeste,togo,fixkostenGesamt,personalGesamt,einkaufGesamt,foodCostPct,personalPct,fixPct,avgBon,db,ebit,tageCount:te.length };
}

// ════════════════════════════════════════════════════
// DASHBOARD – with simplified labels
