}

function prefillBreakevenFromData() {
  const m = getCurrentMonth();
  const d = getMonthData(m);
  if(d.umsatz === 0) { toast('Erst Tageseinträge erfassen'); return; }
  const tage = d.tageCount || 25;
  const bon = d.gaeste > 0 ? d.umsatz / d.gaeste : 22;
  // Variable cost per guest = (food + labor) / guests
  const varPerGast = d.gaeste > 0 ? (d.einkaufGesamt + d.personalGesamt) / d.gaeste : bon * 0.6;
  const fixM = d.fixkostenGesamt || 4500;
  document.getElementById('be-fixkosten').value = Math.round(fixM);
  document.getElementById('be-varkosten').value = Math.round(varPerGast*100)/100;
  document.getElementById('be-bon').value = Math.round(bon*100)/100;
  document.getElementById('be-tage').value = tage;
  updateBreakeven();
  toast('✓ Werte aus deinen Daten übernommen');
}

function updateBreakeven() {
  const fixM   = parseFloat(document.getElementById('be-fixkosten')?.value) || 4500;
  const varK   = parseFloat(document.getElementById('be-varkosten')?.value) || 9.50;
  const bon    = parseFloat(document.getElementById('be-bon')?.value) || 22;
  const tageM  = parseFloat(document.getElementById('be-tage')?.value) || 25;

  const deckBeitrag = bon - varK; // contribution margin per guest
  if(deckBeitrag <= 0) {
    document.getElementById('be-result').innerHTML = '<div class="alert alert-red"><span class="alert-icon">⚠️</span><div class="alert-content"><h4>Variable Kosten übersteigen den Bon!</h4><p>Erhöhe deine Preise oder senke die variablen Kosten.</p></div></div>';
    return;
  }

  const beGaesteMonat = fixM / deckBeitrag;
  const beGaesteTaeglich = beGaesteMonat / tageM;
  const beUmsatz = beGaesteMonat * bon;
  const beUmsatzTaeglich = beGaesteTaeglich * bon;
  const dbPct = bon > 0 ? (deckBeitrag/bon*100) : 0;

  // Current position
  const m = getCurrentMonth();
  const d = getMonthData(m);
  const currentGaeste = d.gaeste;
  const abstand = currentGaeste - beGaesteMonat;
  const pctZurBE = beGaesteMonat > 0 ? (currentGaeste/beGaesteMonat*100) : 0;

  const isProfit = currentGaeste >= beGaesteMonat;
  const safetyMargin = beGaesteMonat > 0 ? ((currentGaeste - beGaesteMonat) / beGaesteMonat * 100) : 0;

  document.getElementById('be-result').innerHTML = `
    <div style="display:flex;flex-direction:column;gap:.75rem">
      <div style="background:${isProfit?'rgba(22,163,74,.1)':'rgba(220,38,38,.1)'};border:1.5px solid ${isProfit?'var(--green)':'var(--red)'};border-radius:10px;padding:1rem;text-align:center">
        <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:${isProfit?'var(--green)':'var(--red)'}">Break-even Punkt</div>
        <div style="font-size:2rem;font-weight:900;color:${isProfit?'var(--green)':'var(--red)'};">${Math.ceil(beGaesteMonat).toLocaleString('de-DE')}</div>
        <div style="font-size:.78rem;color:var(--ink2)">Gäste/Monat · ${Math.ceil(beGaesteTaeglich)} pro Tag</div>
        <div style="font-size:.78rem;color:var(--ink3);margin-top:.2rem">= ${fmtEur(beUmsatz)} Umsatz/Monat</div>
      </div>
      <div style="padding:.6rem 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between">
        <span style="font-size:.82rem;font-weight:600">Deckungsbeitrag pro Gast</span>
        <span style="font-size:.88rem;font-weight:800;color:var(--green)">${fmtEur(deckBeitrag)} (${fmtPct(dbPct)})</span>
      </div>
      ${currentGaeste > 0 ? `
      <div style="padding:.6rem 0;border-bottom:1px solid var(--border)">
        <div style="display:flex;justify-content:space-between;margin-bottom:.4rem">
          <span style="font-size:.82rem;font-weight:600">Aktuell (${currentGaeste} Gäste)</span>
          <span style="font-size:.82rem;font-weight:700;color:${isProfit?'var(--green)':'var(--red)'}">
            ${isProfit?'+'+Math.round(abstand):Math.round(abstand)} Gäste zum BE
          </span>
        </div>
        <div style="height:8px;background:var(--border);border-radius:4px">
          <div style="height:8px;border-radius:4px;background:${isProfit?'var(--green)':'var(--orange)'};width:${Math.min(100,pctZurBE)}%;transition:width .4s"></div>
        </div>
