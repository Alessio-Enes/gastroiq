const DEFAULT_SHIFT_TYPES = {
  morgen: { label:'Frühschicht',  color:'#dbeafe', textColor:'#1e40af', start:'07:00', end:'15:00', hours:8  },
  mittag: { label:'Mittelschicht',color:'#ffedd5', textColor:'#9a3412', start:'11:00', end:'19:00', hours:8  },
  abend:  { label:'Spätschicht',  color:'#ede9fe', textColor:'#5b21b6', start:'15:00', end:'23:00', hours:8  },
  nacht:  { label:'Nachtschicht', color:'#1e293b', textColor:'#94a3b8', start:'22:00', end:'06:00', hours:8  },
  custom: { label:'Individuell',  color:'#f1f5f9', textColor:'#334155', start:'', end:'', hours:0 }
