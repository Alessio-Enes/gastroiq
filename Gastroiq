async function saveVerbrauch() {
  const artikel = document.getElementById('vb-artikel').value;
  if(!artikel) { toast('Artikel erforderlich'); return; }
  const payload = { artikel, kategorie:document.getElementById('vb-kat').value, einkauf:parseFloat(document.getElementById('vb-einkauf-inp').value)||0, verbrauch:parseFloat(document.getElementById('vb-verbrauch-inp').value)||0, datum:document.getElementById('vb-datum').value };
  if(!DEMO_MODE && db && currentUser) {
    const { data, error } = await db.from('verbrauch').insert({ ...payload, user_id: currentUser.id }).select().single();
    if(error) { toast('Fehler: '+error.message); return; }
    state.verbrauch.push(remapVerbrauch(data));
  } else {
    state.verbrauch.push({ id:uid(), ...payload }); save();
  }
  closeModal('modal-verbrauch'); renderVerbrauch(); toast('✓ Einkauf gespeichert');
}

function renderVerbrauch() {
  const m = getCurrentMonth();
  const vb = state.verbrauch.filter(v=>monthStr(v.datum)===m);
  const einkaufGes = vb.reduce((s,v)=>s+(v.einkauf||0),0);
  const verbrauchGes = vb.reduce((s,v)=>s+(v.verbrauch||0),0);
  const schwund = einkaufGes - verbrauchGes;
  document.getElementById('vb-einkauf').textContent = fmtEur(einkaufGes);
  document.getElementById('vb-schwund').textContent = fmtEur(Math.max(0,schwund));
  document.getElementById('vb-quote').textContent = einkaufGes>0?fmtPct(verbrauchGes/einkaufGes*100):'0%';

  document.getElementById('verbrauch-tbody').innerHTML = vb.map(v=>{
    const sw = Math.max(0,v.einkauf-v.verbrauch);
    return `<tr><td class="td-bold">${v.artikel}</td><td>${v.kategorie}</td><td>${fmtEur(v.einkauf)}</td><td>${fmtEur(v.verbrauch)}</td>
    <td><span class="badge ${sw>0?'badge-red':'badge-green'}">${fmtEur(sw)}</span></td>
    <td>${v.datum?v.datum.split('-').reverse().join('.'):'–'}</td></tr>`;
  }).join('');

  const katMap = {};
  vb.forEach(v=>{ katMap[v.kategorie]=(katMap[v.kategorie]||0)+(v.einkauf||0); });
  destroyChart('chart-verbrauch');
  const ctx = document.getElementById('chart-verbrauch');
  if(ctx && Object.keys(katMap).length>0) dashCharts['chart-verbrauch'] = new Chart(ctx,{
    type:'doughnut', data:{ labels:Object.keys(katMap), datasets:[{ data:Object.values(katMap), backgroundColor:['#d95f0a','#1a56db','#0d9265','#6d28d9','#a16207','#c0261d','#0ea5e9'], borderWidth:2, borderColor:'#fff' }]},
    options:{...pieChartOpts('bottom')}
  });
}

