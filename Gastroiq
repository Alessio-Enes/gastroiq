let editingMaId = null;

function openEditMitarbeiter(id) {
  const m = state.personal.find(p => p.id === id);
  if(!m) return;
  editingMaId = id;
  document.getElementById('ma-modal-title').textContent = '✏️ Mitarbeiter bearbeiten';
  document.getElementById('m-name').value = m.name;
  document.getElementById('m-rolle').value = m.rolle;
  document.getElementById('m-lohn').value = m.lohn || 13.50;
  document.getElementById('m-std').value = m.stunden || 80;
  document.getElementById('m-wunschfrei').value = (m.wunschfrei || []).join(', ');
  // Set verfügbarkeit checkboxes
  const verfueg = m.verfueg || DAY_NAMES;
  document.querySelectorAll('.m-verfueg-cb').forEach(cb => {
    cb.checked = verfueg.includes(cb.value);
  });
