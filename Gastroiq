    { label:'− Zutatenkosten', val:-d.einkaufGesamt, color:'var(--red)' },
    { label:'= Rohgewinn', val:d.db, bold:true, color:d.db>=0?'var(--green)':'var(--red)', hint:'Umsatz nach Abzug der Zutatenkosten' },
    { label:'− Personalkosten', val:-d.personalGesamt, color:'var(--red)' },
    { label:'= Ergebnis nach Personal', val:d.db-d.personalGesamt, bold:true, color:(d.db-d.personalGesamt)>=0?'var(--green)':'var(--red)' },
    { label:'− Fixkosten (Miete, Strom etc.)', val:-d.fixkostenGesamt, color:'var(--red)' },
    { label:'= Betriebsergebnis', val:d.ebit, bold:true, color:d.ebit>=0?'var(--green)':'var(--red)', hint:d.ebit>=0?'Ihr Gewinn dieses Monats':'Ihr Verlust – Handlungsbedarf' },
  ];
  document.getElementById('guv-container').innerHTML = guvRows.map(r=>`
    <div style="padding:.55rem 0;border-bottom:1px solid var(--border);${r.bold?'background:var(--bg);margin:0 -1rem;padding:.6rem 1rem;border-radius:4px;':''}">
      <div style="display:flex;justify-content:space-between;align-items:center">
