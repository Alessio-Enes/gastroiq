function checkShiftOverlapPreview(empId, dateStr, start, end) {
  const warn = document.getElementById('schicht-overlap-warning');
  const txt  = document.getElementById('schicht-overlap-text');
  if(!start || !end) { warn.style.display = 'none'; return; }
  const overlapping = findOverlapsForEmployee(empId, dateStr, start, end);
  if(overlapping.length > 0) {
    warn.style.display = 'flex';
    txt.textContent = overlapping.join('; ');
  } else {
    warn.style.display = 'none';
  }
}

function timeToMin(t) {
  const [h, m] = t.split(':').map(Number);
  return h * 60 + m;
}

function timesOverlap(s1, e1, s2, e2) {
  // Handle overnight shifts by adding 24h to end if end < start
  let sm1 = timeToMin(s1), em1 = timeToMin(e1);
  let sm2 = timeToMin(s2), em2 = timeToMin(e2);
  if(em1 <= sm1) em1 += 1440;
  if(em2 <= sm2) em2 += 1440;
  return sm1 < em2 && sm2 < em1;
}

function findOverlapsForEmployee(empId, dateStr, newStart, newEnd) {
  // Check: same employee on adjacent days (fatigue: <11h rest)
  const warnings = [];
  if(!newStart || !newEnd) return warnings;
  const emp = state.personal.find(p => p.id === empId);
  if(!emp) return warnings;

  // Check previous day – if employee had night/late shift
  const prev = new Date(dateStr); prev.setDate(prev.getDate() - 1);
  const prevStr = prev.toISOString().split('T')[0];
  const prevShift = state.shifts[shiftKey(empId, prevStr)];
  if(prevShift?.end && prevShift?.start) {
    // calc end time on prev day in absolute minutes
    let prevEndMin = timeToMin(prevShift.end);
    if(prevEndMin <= timeToMin(prevShift.start)) prevEndMin += 1440; // overnight
    const prevEndAbs = prevEndMin; // minutes after midnight of prevDay
    const newStartAbs = timeToMin(newStart) + 1440; // +24h for next day
    const restHours = (newStartAbs - prevEndAbs) / 60;
    if(restHours < 11) {
      warnings.push('Ruhezeit nach gestern nur ' + restHours.toFixed(1) + ' h (gesetzl. Mind. 11 h)');
    }
  }

  // Check next day – if employee has morning shift after this one
  const next = new Date(dateStr); next.setDate(next.getDate() + 1);
  const nextStr = next.toISOString().split('T')[0];
  const nextShift = state.shifts[shiftKey(empId, nextStr)];
  if(nextShift?.start && nextShift?.end) {
    let curEndMin = timeToMin(newEnd);
    if(curEndMin <= timeToMin(newStart)) curEndMin += 1440;
    const nextStartAbs = timeToMin(nextShift.start) + 1440;
    const restHours = (nextStartAbs - curEndMin) / 60;
    if(restHours < 11) {
      warnings.push('Ruhezeit bis morgen nur ' + restHours.toFixed(1) + ' h (gesetzl. Mind. 11 h)');
    }
  }

  // Same day same time: other employees with SAME role – over-coverage?
  const sameDayShifts = state.personal
    .filter(p => p.id !== empId && state.shifts[shiftKey(p.id, dateStr)]?.start && state.shifts[shiftKey(p.id, dateStr)]?.end)
    .filter(p => p.rolle === emp.rolle)
    .filter(p => {
      const s = state.shifts[shiftKey(p.id, dateStr)];
      return timesOverlap(newStart, newEnd, s.start, s.end);
    });
  if(sameDayShifts.length > 0) {
    warnings.push('Gleiche Rolle (' + emp.rolle + ') überschneidet sich mit: ' + sameDayShifts.map(p => p.name).join(', '));
  }

  return warnings;
}

