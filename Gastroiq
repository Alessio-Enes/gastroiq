// ── FORM VALIDATION (Tageseintrag) ────────────────────────────
function teValidate() {
  const datum   = document.getElementById('te-datum')?.value;
  const umsatz  = parseFloat(document.getElementById('te-umsatz-inp')?.value);
  const gaeste  = parseInt(document.getElementById('te-gaeste-inp')?.value);

  const setHint = (id, cls, msg) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.className = 'val-hint' + (cls ? ' ' + cls : '');
    el.textContent = msg;
    el.style.display = (cls && msg) ? 'block' : 'none';
  };

  // Datum
  if (datum) {
    const d = new Date(datum);
    const today = new Date(); today.setHours(23,59,59);
    if (d > today) {
      setHint('vh-datum', 'error', '⛔ Datum liegt in der Zukunft');
    } else {
      // Check for duplicate
      const exists = state.tageseintraege.some(t => t.datum === datum && t.id !== teEditId);
      setHint('vh-datum', exists ? 'warning' : '', exists ? '⚠️ Für dieses Datum existiert bereits ein Eintrag – er wird überschrieben' : '');
    }
  } else {
    setHint('vh-datum', '', '');
  }

  // Umsatz
  if (!isNaN(umsatz)) {
    if (umsatz <= 0) setHint('vh-umsatz', 'error', '⛔ Umsatz muss größer als 0 sein');
    else if (umsatz > 50000) setHint('vh-umsatz', 'warning', '⚠️ Umsatz über 50.000 € – bitte prüfen');
    else setHint('vh-umsatz', '', '');
  } else { setHint('vh-umsatz', '', ''); }

  // Gäste
  if (!isNaN(gaeste)) {
    if (gaeste <= 0) setHint('vh-gaeste', 'error', '⛔ Gästeanzahl muss größer als 0 sein');
    else if (gaeste > 2000) setHint('vh-gaeste', 'warning', '⚠️ Über 2.000 Gäste – bitte prüfen');
    else setHint('vh-gaeste', '', '');
  } else { setHint('vh-gaeste', '', ''); }

  // Plausibility cross-check
  if (!isNaN(umsatz) && !isNaN(gaeste) && umsatz > 0 && gaeste > 0) {
    const avgBon = umsatz / gaeste;
    if (avgBon < 3) {
      setHint('vh-plausib', 'warning', `⚠️ Ø Bon: ${avgBon.toFixed(2)} € – unrealistisch niedrig (< 3 €/Gast)`);
    } else if (avgBon > 200) {
      setHint('vh-plausib', 'warning', `⚠️ Ø Bon: ${avgBon.toFixed(2)} € – unrealistisch hoch (> 200 €/Gast)`);
    } else {
      setHint('vh-plausib', 'ok', `✓ Ø Bon: ${avgBon.toFixed(2)} € pro Gast – plausibel`);
    }
  } else {
    setHint('vh-plausib', '', '');
  }
}
let teEditId = null; // tracks which entry is being edited (for duplicate check)

// ── Zahlungsarten live sum check ─────────────────────────────
function teUpdateZahlungsSumme() {
  const umsatz = parseFloat(document.getElementById('te-umsatz-inp')?.value) || 0;
  const bar     = parseFloat(document.getElementById('te-bar')?.value) || 0;
  const karte   = parseFloat(document.getElementById('te-karte')?.value) || 0;
  const digital = parseFloat(document.getElementById('te-digital')?.value) || 0;
  const summe = Math.round((bar + karte + digital) * 100) / 100;
  const el = document.getElementById('zahlung-check');
  if (!el) return;
  if (summe === 0) { el.textContent = ''; return; }
  const diff = Math.abs(summe - umsatz);
  if (umsatz > 0 && diff > 0.05) {
    el.innerHTML = `⚠️ Summe Bar+Karte+Digital = <strong>${fmtEur(summe)}</strong> – weicht vom Umsatz (${fmtEur(umsatz)}) um ${fmtEur(diff)} ab`;
    el.style.color = 'var(--orange)';
  } else if (umsatz > 0) {
    el.innerHTML = `✓ Stimmt mit Umsatz überein (${fmtEur(summe)})`;
    el.style.color = 'var(--green)';
  }
}

// ── DATA QUALITY WIDGET ───────────────────────────────────────
function renderDatenqualitaet(monat) {
  const widget = document.getElementById('dq-widget');
  if (!widget) return;

  const allEntries = state.tageseintraege || [];
  if (allEntries.length === 0) { widget.style.display = 'none'; return; }

  // Parse current month from filter or default
  const [yr, mo] = monat.split('-').map(Number);
  const daysInMonth = new Date(yr, mo, 0).getDate();
  const today = new Date();
  const isCurrentMonth = (yr === today.getFullYear() && mo === today.getMonth() + 1);
  const maxDay = isCurrentMonth ? today.getDate() : daysInMonth;

  // Entries for this month
  const monthStr = monat;
  const entries = allEntries.filter(t => (t.datum || '').startsWith(monthStr));

  if (entries.length === 0 && !isCurrentMonth) { widget.style.display = 'none'; return; }

  // Categorize entries
  let okCount = 0, partialCount = 0;
  const weFehlendeTage = [];

  entries.forEach(t => {
    const hasWe = t._wareneinsatzFehlt !== true; // flag set by POS import
    if (hasWe) okCount++;
    else { partialCount++; weFehlendeTage.push(t.datum); }
  });

  const missingDays = maxDay - entries.length;
  const total = maxDay;
  const pct = Math.round((okCount / total) * 100);

  // Find up to 5 missing dates
  const entryDates = new Set(entries.map(t => t.datum));
  const missingDates = [];
  for (let d = 1; d <= maxDay && missingDates.length < 5; d++) {
    const ds = `${yr}-${String(mo).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    if (!entryDates.has(ds)) missingDates.push(ds.split('-').reverse().join('.'));
  }

  // Update widget
  widget.style.display = 'block';
  document.getElementById('dq-pct').textContent = `${pct}%`;
  document.getElementById('dq-pct').style.color = pct >= 80 ? 'var(--green)' : pct >= 50 ? 'var(--yellow)' : 'var(--red)';
  document.getElementById('dq-bar').style.width = pct + '%';
  document.getElementById('dq-bar').style.background = pct >= 80 ? 'var(--green)' : pct >= 50 ? 'var(--yellow)' : 'var(--red)';
  document.getElementById('dq-ok-count').textContent = `${okCount} vollständig`;
  document.getElementById('dq-partial-count').textContent = `${partialCount} ohne Wareneinsatz`;
  document.getElementById('dq-missing-count').textContent = `${Math.max(0,missingDays)} Tage fehlen noch`;

  // Wareneinsatz warning
  const weWarn = document.getElementById('dq-we-warn');
  const weCnt = document.getElementById('dq-we-count');
  if (partialCount > 0) {
    weWarn.style.display = 'block';
    weCnt.textContent = partialCount;
  } else { weWarn.style.display = 'none'; }

  // Missing dates hint
  const lücken = document.getElementById('dq-lücken');
  if (missingDates.length > 0) {
    lücken.style.display = 'block';
    lücken.textContent = `Fehlende Tage: ${missingDates.join(', ')}${missingDays > 5 ? ` … +${missingDays - 5} weitere` : ''}`;
  } else { lücken.style.display = 'none'; }
}

// ── POS-MODE DETECTION ────────────────────────────────────────
function csvIsPOSMode() {
  const h = csvState.headers;
  const hasBon  = h.some(x => /bonnr|bon.?nr|bon.?num|belegn|receipt.?id|check.?id/i.test(x));
  const hasItem = h.some(x => /gericht|artikel|item|dish|product/i.test(x));
  const hasMenge= h.some(x => /menge|qty|quantity|anzahl/i.test(x));
  const hasKat  = h.some(x => /kategorie|category|gruppe|group/i.test(x));
  return hasBon || (hasItem && hasMenge) || (hasItem && hasKat);
}

// ── POS AGGREGATION ───────────────────────────────────────────
function csvAggregatePOS() {
  const h = csvState.headers;
  const idx = (...pats) => {
    for (const p of pats) {
      const i = h.findIndex(x => p.test(x));
      if (i >= 0) return i;
    }
    return -1;
  };

  const iDatum   = idx(/datum/i, /date/i, /tag/i);
  const iUmsatz  = idx(/umsatz/i, /betrag/i, /total/i, /revenue/i, /amount/i);
  const iBonNr   = idx(/bonnr/i, /bon.?nr/i, /bon/i, /belegn/i, /check/i, /receipt/i);
  const iKat     = idx(/kategorie/i, /category/i, /gruppe/i);
  const iService = idx(/serviceart/i, /service/i, /type/i);
  const iGericht = idx(/gericht/i, /artikel/i, /dish/i, /product/i, /item/i);
  const iMenge   = idx(/menge/i, /qty/i, /quantity/i, /anzahl/i, /count/i);
  const iGaeste  = idx(/gäste/i, /gaeste/i, /guests/i, /covers/i, /persons/i);
  const iEinzel  = idx(/einzelpreis/i, /unit.?price/i, /preis/i, /price/i);
  const iMwSt    = idx(/mwst/i, /tax/i, /steuer/i, /vat/i);
  const iZahlung = idx(/zahlungsart/i, /payment/i, /pay/i);

  if (iDatum < 0 || iUmsatz < 0) return null;

  const tage = {};
  const validationErrors = [];
  const bonGaesteMap = {}; // bonNr → gaeste count (to avoid double-counting)

  csvState.rows.forEach((row, rowIdx) => {
    const rawDatum = row[iDatum];
    const datum = csvParseDate(rawDatum);
    if (!datum) {
      if (rowIdx < 5) validationErrors.push({ type: 'datum', msg: `Zeile ${rowIdx+2}: Datum "${rawDatum}" konnte nicht geparst werden` });
      return;
    }

    if (!tage[datum]) {
      tage[datum] = {
        datum, umsatz: 0, gaeste: 0, togo: 0, getraenke: 0,
        bonSet: new Set(), togoSet: new Set(),
        gerichtZaehler: {}, zahlungsarten: {}, warnings: []
      };
    }
    const tag = tage[datum];

    const umsatz  = csvParseNum(row[iUmsatz]) || 0;
    const bonNr   = iBonNr >= 0 ? String(row[iBonNr] || '').trim() : null;
    const kat     = iKat >= 0 ? String(row[iKat] || '').toLowerCase() : '';
    const service = iService >= 0 ? String(row[iService] || '').toLowerCase() : '';
    const gericht = iGericht >= 0 ? String(row[iGericht] || '').trim() : '';
    const menge   = iMenge >= 0 ? (csvParseNum(row[iMenge]) || 1) : 1;
    const einzelp = iEinzel >= 0 ? csvParseNum(row[iEinzel]) : null;
    const mwst    = iMwSt >= 0 ? csvParseNum(row[iMwSt]) : null;

    // ── Umsatz
    tag.umsatz += umsatz;

    // ── Getränke detection
    if (/getr[äa]nke|drink|beverage|bier|wein|wasser|saft|espresso|kaffee|cola|fanta|sprite|bier|wein/i.test(kat + ' ' + gericht)) {
      tag.getraenke += umsatz;
    }

    // ── Gäste – count from unique BonNr only (avoid duplicates per line item)
    if (bonNr) {
      const isTakeaway = /takeaway|togo|to.?go|liefering|delivery|abholung/i.test(service);
      if (!tag.bonSet.has(bonNr)) {
        tag.bonSet.add(bonNr);
        let gaeste = iGaeste >= 0 ? (parseInt(row[iGaeste]) || 1) : 1;
        if (!bonGaesteMap[bonNr]) bonGaesteMap[bonNr] = gaeste;
        else gaeste = bonGaesteMap[bonNr]; // use consistent value
        if (isTakeaway) {
          tag.togoSet.add(bonNr);
          tag.togo += gaeste;
        } else {
          tag.gaeste += gaeste;
        }
      }
    } else {
      // No BonNr – count rows as 1 guest each
      tag.gaeste += 1;
    }

    // ── Top-Gericht
    if (gericht && !/getr[äa]nke/i.test(kat)) {
      tag.gerichtZaehler[gericht] = (tag.gerichtZaehler[gericht] || 0) + menge;
    }

    // ── VALIDATION: Rechenprüfung (Einzelpreis × Menge ≈ Umsatz)
    if (einzelp !== null && menge !== null && umsatz > 0) {
      const expected = Math.round(einzelp * menge * 100) / 100;
      if (Math.abs(expected - umsatz) > 0.05 && validationErrors.filter(e=>e.type==='rechnung').length < 10) {
        validationErrors.push({
          type: 'rechnung',
          msg: `Zeile ${rowIdx+2}: ${fmtEur(einzelp)} × ${menge} = ${fmtEur(expected)} ≠ ${fmtEur(umsatz)} (Δ ${fmtEur(Math.abs(expected-umsatz))})`
        });
      }
    }

    // ── VALIDATION: MwSt-Plausibilität
    if (mwst !== null && umsatz > 0) {
      const e19 = Math.round(umsatz / 1.19 * 0.19 * 100) / 100;
      const e7  = Math.round(umsatz / 1.07 * 0.07 * 100) / 100;
      const tol = Math.max(0.02, umsatz * 0.002);
      if (Math.abs(mwst - e19) > tol && Math.abs(mwst - e7) > tol && validationErrors.filter(e=>e.type==='mwst').length < 10) {
        validationErrors.push({
          type: 'mwst',
          msg: `Zeile ${rowIdx+2}: MwSt ${fmtEur(mwst)} auf ${fmtEur(umsatz)} passt weder zu 19% (${fmtEur(e19)}) noch 7% (${fmtEur(e7)})`
        });
      }
    }

    // ── Zahlungsarten
    if (iZahlung >= 0) {
      const zahlung = String(row[iZahlung] || '').toLowerCase();
      if (/bar|cash/i.test(zahlung)) tag.barUmsatz = (tag.barUmsatz || 0) + umsatz;
      else if (/karte|card|ec|kredit/i.test(zahlung)) tag.karteUmsatz = (tag.karteUmsatz || 0) + umsatz;
      else if (/apple.?pay|google.?pay|paypal|digital|nfc|kontaktlos/i.test(zahlung)) tag.digitalUmsatz = (tag.digitalUmsatz || 0) + umsatz;
      else tag.karteUmsatz = (tag.karteUmsatz || 0) + umsatz; // fallback: treat unknown as card
    }
  });

  // ── Convert to aggregated day records
  const aggregated = Object.values(tage).map(t => ({
    datum:       t.datum,
    umsatz:      Math.round(t.umsatz * 100) / 100,
    gaeste:      t.gaeste,
    togo:        t.togo,
    getraenke:   Math.round(t.getraenke * 100) / 100,
    topGericht:  Object.entries(t.gerichtZaehler).sort((a,b) => b[1]-a[1])[0]?.[0] || '',
    notiz:       t.warnings.length ? '⚠ ' + t.warnings.join('; ') : '',
    barUmsatz:   Math.round((t.barUmsatz || 0) * 100) / 100,
    karteUmsatz: Math.round((t.karteUmsatz || 0) * 100) / 100,
    digitalUmsatz: Math.round((t.digitalUmsatz || 0) * 100) / 100,
    source:      'import:csv-pos',
    _wareneinsatzFehlt: true,
  }));

  return { aggregated, validationErrors, totalInputRows: csvState.rows.length, totalBons: Object.keys(bonGaesteMap).length };
}

// ── RENDER POS PREVIEW (Step 2) ───────────────────────────────
function csvRenderPOSPreview() {
  const res = csvAggregatePOS();
  if (!res) return;
  csvState._posResult = res;

  const { aggregated, validationErrors, totalInputRows, totalBons } = res;
  const totalUmsatz = aggregated.reduce((s, r) => s + r.umsatz, 0);

  // Stats grid
  document.getElementById('pos-preview-stats').innerHTML = `
    <div class="pos-stat"><div class="pos-stat-num">${totalInputRows.toLocaleString('de-DE')}</div><div class="pos-stat-lbl">Einzelpositionen</div></div>
    <div class="pos-stat"><div class="pos-stat-num">${totalBons.toLocaleString('de-DE')}</div><div class="pos-stat-lbl">Bons gesamt</div></div>
    <div class="pos-stat"><div class="pos-stat-num">${aggregated.length}</div><div class="pos-stat-lbl">Tage erkannt</div></div>
    <div class="pos-stat"><div class="pos-stat-num">${fmtEur(totalUmsatz)}</div><div class="pos-stat-lbl">Gesamtumsatz</div></div>
  `;

  // Validation warnings
  const warnBox = document.getElementById('pos-warn-container');
  const errBox  = document.getElementById('pos-err-container');

  // General warnings
  const warnings = [];
  if (aggregated.some(r => r.getraenke === 0)) warnings.push('Bei einigen Tagen konnten keine Getränke-Positionen erkannt werden – Kategorie prüfen.');
  if (aggregated.some(r => r.gaeste === 0)) warnings.push('Für einzelne Tage wurden keine Gäste erkannt – Gäste-Spalte prüfen.');

  warnBox.innerHTML = warnings.length ? `<div class="pos-warnings-box">
    <div style="font-weight:700;font-size:.8rem;margin-bottom:.4rem">⚠️ Hinweise (${warnings.length})</div>
    ${warnings.map(w => `<div class="pos-warn-item"><span class="wi">•</span><span>${w}</span></div>`).join('')}
  </div>` : '';

  // Data errors
  const rechenFehler = validationErrors.filter(e => e.type === 'rechnung');
  const mwstFehler   = validationErrors.filter(e => e.type === 'mwst');
  const datumFehler  = validationErrors.filter(e => e.type === 'datum');
  let errHtml = '';
  if (validationErrors.length > 0) {
    errHtml = `<div class="pos-err-box">
      <div style="font-weight:700;font-size:.8rem;margin-bottom:.4rem;color:var(--red)">🔴 Datenfehler gefunden (${validationErrors.length})</div>`;
    if (datumFehler.length) errHtml += `<div style="font-weight:600;margin:.3rem 0 .15rem">Datum nicht parsebar (${datumFehler.length}):</div>` + datumFehler.map(e => `<div class="pos-err-item">${e.msg}</div>`).join('');
    if (rechenFehler.length) errHtml += `<div style="font-weight:600;margin:.3rem 0 .15rem">Rechenabweichungen (${rechenFehler.length}):</div>` + rechenFehler.map(e => `<div class="pos-err-item">${e.msg}</div>`).join('');
    if (mwstFehler.length) errHtml += `<div style="font-weight:600;margin:.3rem 0 .15rem">MwSt-Abweichungen (${mwstFehler.length}):</div>` + mwstFehler.map(e => `<div class="pos-err-item">${e.msg}</div>`).join('');
    errHtml += '</div>';
  }
  errBox.innerHTML = errHtml;
}

