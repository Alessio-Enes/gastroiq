function renderPrognose() {
  const months = ['2025-06','2025-07','2025-08','2025-09','2025-10','2025-11'];
  const typ = document.getElementById('restaurant-typ')?.value||'restaurant';
  const typKey = Object.keys(saisonIndex).find(k=>typ.toLowerCase().includes(k))||'restaurant';
  const uData = months.map(m=>getMonthData(m).umsatz).filter(v=>v>0);
  const avgUmsatz = uData.length>0 ? uData.reduce((s,v)=>s+v,0)/uData.length : 15000;
  const avgGaeste = state.tageseintraege.length>0 ? state.tageseintraege.reduce((s,t)=>s+(t.gaeste||0),0)/Math.max(1,state.tageseintraege.length)*30 : 600;

  const nextMonth = 11;
  const forecastUmsatz = avgUmsatz * saisonIndex[typKey][nextMonth];
  document.getElementById('fc-umsatz').textContent = fmtEur(forecastUmsatz);
  document.getElementById('fc-gaeste').textContent = Math.round(avgGaeste * saisonIndex[typKey][nextMonth]).toLocaleString('de-DE');
  document.getElementById('fc-einkauf').textContent = fmtEur(forecastUmsatz * ((state.settings.fcZiel||28)/100));

  const fLabels = ['Dez','Jan','Feb','Mär','Apr','Mai'];
  const fIdxs = [11,0,1,2,3,4];
  const fData = fIdxs.map(i => avgUmsatz * saisonIndex[typKey][i]);
  destroyChart('chart-forecast');
  const ctx1 = document.getElementById('chart-forecast');
  if(ctx1) dashCharts['chart-forecast'] = new Chart(ctx1,{ type:'bar', data:{ labels:fLabels, datasets:[{ label:'Prognose (€)', data:fData, backgroundColor:fData.map(v=>v>=avgUmsatz?'rgba(22,163,74,.5)':'rgba(37,99,235,.5)'), borderColor:fData.map(v=>v>=avgUmsatz?'#16a34a':'#2563eb'), borderWidth:2 }]}, options:{...chartOpts(), plugins:{legend:{display:false}}} });

  const sLabels = ['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'];
