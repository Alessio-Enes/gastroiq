        <div style="min-width:0">
          <div style="font-size:.85rem;font-weight:600;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${f.art}</div>
          ${f.beschreibung ? `<div style="font-size:.7rem;color:var(--ink3)">${f.beschreibung}</div>` : ''}
          <span class="badge ${f.typ==='fix'?'badge-blue':'badge-orange'}" style="margin-top:.2rem">${f.typ==='fix'?'Fixbetrag':'Variabel'}</span>
        </div>
      </div>
      <div style="text-align:right;flex-shrink:0">
        <div style="font-weight:700;font-size:.92rem">${fmtEur(f.betrag)}${jaehrl}</div>
        <div style="font-size:.68rem;color:var(--ink3)">${pct}% der Fixkosten</div>
