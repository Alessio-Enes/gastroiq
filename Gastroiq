<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GastroIQ – Intelligentes Restaurant-Controlling</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;0,9..144,900;1,9..144,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#faf7f2;
  --surface:#ffffff;
  --surface2:#f3ede3;
  --ink:#1a1208;
  --ink2:#4a3f2f;
  --ink3:#8a7a65;
  --ink4:#b8a898;
  --primary:#c8440a;
  --primary-light:#fff0eb;
  --accent:#e8873a;
  --green:#2d6a4f;
  --green-light:#eaf4ef;
  --orange:#c8440a;
  --orange-light:#fff0eb;
  --red:#b91c1c;
  --red-light:#fef2f2;
  --yellow:#b8860b;
  --yellow-light:#fef8e7;
  --purple:#6d28d9;
  --purple-light:#f5f3ff;
  --navy:#1a1208;
  --border:#e8ddd0;
  --border2:#d5c9b8;
  --shadow:0 1px 3px rgba(26,18,8,.06),0 1px 2px rgba(26,18,8,.04);
  --shadow-md:0 4px 8px rgba(26,18,8,.08),0 2px 4px rgba(26,18,8,.04);
  --shadow-lg:0 10px 28px rgba(26,18,8,.1),0 4px 10px rgba(26,18,8,.05);
  --radius:12px;
  --radius-sm:8px;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--ink);font-family:'DM Sans',sans-serif;min-height:100vh;display:flex}

/* SIDEBAR */
.sidebar{width:240px;min-height:100vh;background:#13100d;position:fixed;top:0;left:0;bottom:0;display:flex;flex-direction:column;z-index:100;border-right:1px solid rgba(255,255,255,.06)}
.sidebar-logo{padding:1.25rem 1.15rem .9rem;border-bottom:1px solid rgba(255,255,255,.07)}
.logo-mark{font-family:'Fraunces',serif;font-size:1.25rem;font-weight:900;color:white;letter-spacing:-.03em}
.logo-mark span{color:var(--primary)}
.logo-sub{font-size:.63rem;color:rgba(255,255,255,.3);margin-top:.2rem;letter-spacing:.06em;text-transform:uppercase}
.sidebar-nav{padding:.5rem 0 .5rem;flex:1;overflow-y:auto}

/* DRILLDOWN NAV */
.nav-cat{margin-bottom:.05rem}
.nav-cat-header{display:flex;align-items:center;gap:.6rem;padding:.58rem 1rem;cursor:pointer;transition:background .15s,color .15s;font-size:.75rem;font-weight:700;color:rgba(255,255,255,.38);border-left:3px solid transparent;user-select:none;text-transform:uppercase;letter-spacing:.06em}
.nav-cat-header:hover{background:rgba(255,255,255,.04);color:rgba(255,255,255,.7)}
.nav-cat-header .cat-icon{font-size:1rem;width:20px;text-align:center;flex-shrink:0;line-height:1}
.nav-cat-header .cat-arrow{margin-left:auto;font-size:.55rem;transition:transform .2s;color:rgba(255,255,255,.18);flex-shrink:0}
.nav-cat.open .nav-cat-header{background:rgba(200,68,10,.13);color:#ffb89a;border-left-color:rgba(200,68,10,.55)}
.nav-cat.open .cat-arrow{transform:rotate(90deg)}
.nav-sub{max-height:0;overflow:hidden;transition:max-height .28s ease}
.nav-cat.open .nav-sub{max-height:500px}
.nav-sub-item{display:flex;align-items:center;gap:.7rem;padding:.52rem 1rem .52rem 1rem;cursor:pointer;font-size:.8rem;font-weight:500;color:rgba(255,255,255,.42);transition:background .15s,color .15s;border-left:3px solid transparent;border-bottom:1px solid rgba(255,255,255,.03)}
.nav-sub-item:last-child{border-bottom:none}
.nav-sub-item:hover{background:rgba(255,255,255,.05);color:rgba(255,255,255,.82)}
.nav-sub-item.active{color:#ffb89a;background:rgba(200,68,10,.12);border-left-color:var(--primary)}
.nav-item-icon{width:28px;height:28px;border-radius:7px;background:rgba(255,255,255,.05);display:flex;align-items:center;justify-content:center;font-size:.85rem;flex-shrink:0;transition:background .15s}
.nav-sub-item.active .nav-item-icon{background:rgba(200,68,10,.22)}
.nav-sub-item:hover .nav-item-icon{background:rgba(255,255,255,.09)}
.nav-item-text{display:flex;flex-direction:column;gap:.05rem;min-width:0}
.nav-item-label{font-size:.8rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.nav-item-desc{font-size:.67rem;color:rgba(255,255,255,.25);font-weight:400;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.2}
.nav-sub-item.active .nav-item-desc{color:rgba(255,180,120,.45)}
.nav-sub-item:hover .nav-item-desc{color:rgba(255,255,255,.4)}

.sidebar-bottom{padding:.8rem 1rem;border-top:1px solid rgba(255,255,255,.07)}
.sidebar-bottom p{font-size:.65rem;color:rgba(255,255,255,.25);letter-spacing:.02em}
.nav-util{padding:.15rem 0;border-top:1px solid rgba(255,255,255,.06);margin-top:.15rem}
.nav-util-item{display:flex;align-items:center;gap:.65rem;padding:.5rem 1rem;cursor:pointer;font-size:.78rem;font-weight:500;color:rgba(255,255,255,.3);transition:background .15s,color .15s}
.nav-util-item:hover{background:rgba(255,255,255,.04);color:rgba(255,255,255,.65)}

/* MAIN */
.main{margin-left:240px;flex:1;min-height:100vh}
.topbar{background:rgba(250,247,242,.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:.85rem 2rem;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:50}
.topbar-left h1{font-size:1.05rem;font-weight:700;letter-spacing:-.02em;color:var(--ink)}
.topbar-left p{font-size:.75rem;color:var(--ink3);margin-top:.1rem}
.topbar-right{display:flex;gap:.8rem;align-items:center}
.month-selector{display:flex;align-items:center;gap:.5rem;background:var(--surface);border:1px solid var(--border2);border-radius:100px;padding:.42rem .9rem;font-family:inherit;font-size:.82rem;font-weight:600;color:var(--ink2);cursor:pointer;outline:none;box-shadow:var(--shadow)}
.month-selector:focus{border-color:var(--primary)}
.badge-btn{background:var(--primary);color:white;border:none;border-radius:100px;padding:.5rem 1.1rem;font-family:inherit;font-size:.8rem;font-weight:600;cursor:pointer;transition:transform .15s,box-shadow .15s;box-shadow:0 2px 8px rgba(200,68,10,.25)}
.badge-btn:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(200,68,10,.32)}

.content{padding:1.8rem 2rem}
.page{display:none}
.page.active{display:block}

/* CARDS */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.4rem;box-shadow:var(--shadow);transition:box-shadow .2s}
.card-title{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--ink3);margin-bottom:1rem}.section-header h2{font-family:'Fraunces',serif;letter-spacing:-.03em}
.card-title-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem}
.card-title-row .ct{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--ink3)}

/* KPI GRID */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem}
.kpi-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.3rem 1.3rem 1.1rem;box-shadow:var(--shadow);position:relative;overflow:hidden;transition:box-shadow .2s}
.kpi-card:hover{box-shadow:var(--shadow-md)}
.kpi-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.kpi-card.blue::before{background:var(--primary)}
.kpi-card.green::before{background:var(--green)}
.kpi-card.orange::before{background:var(--orange)}
.kpi-card.red::before{background:var(--red)}
.kpi-card.purple::before{background:var(--purple)}
.kpi-card.yellow::before{background:var(--yellow)}
.kpi-icon{display:none}
.kpi-label{font-size:.68rem;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.35rem}
.kpi-value{font-family:'Fraunces',serif;font-size:1.75rem;font-weight:900;letter-spacing:-.04em;color:var(--ink);line-height:1}
.kpi-delta{font-size:.72rem;margin-top:.4rem;font-weight:600}
.kpi-delta.up{color:var(--green)}
.kpi-delta.down{color:var(--red)}
.kpi-delta.neutral{color:var(--ink3)}
.kpi-explain{font-size:.67rem;color:var(--ink3);margin-top:.3rem;line-height:1.4;font-weight:400}
.kpi-abs{font-size:.7rem;color:var(--ink2);margin-top:.2rem;font-weight:600}

/* GRID LAYOUTS */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.2rem}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem}
.grid-2-1{display:grid;grid-template-columns:2fr 1fr;gap:1.2rem}
.grid-1-2{display:grid;grid-template-columns:1fr 2fr;gap:1.2rem}

/* FORM ELEMENTS */
.field{margin-bottom:.9rem}
.field:last-child{margin-bottom:0}
.field label{display:block;font-size:.72rem;font-weight:600;color:var(--ink2);margin-bottom:.35rem;text-transform:uppercase;letter-spacing:.04em}
.field input,.field select,.field textarea{width:100%;padding:.6rem .85rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);background:var(--surface2);font-family:inherit;font-size:.875rem;color:var(--ink);outline:none;transition:border-color .2s,box-shadow .2s}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(200,68,10,.1)}
.field textarea{resize:vertical;min-height:60px}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:.8rem}
.field-row-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.7rem}

/* BUTTONS */
.btn{padding:.58rem 1.15rem;border-radius:var(--radius-sm);font-family:inherit;font-size:.8rem;font-weight:600;cursor:pointer;border:none;transition:transform .15s,box-shadow .15s,background .15s;letter-spacing:.01em}
.btn:hover{transform:translateY(-1px)}
.btn-primary{background:var(--primary);color:white;border-radius:100px!important}
.btn-primary:hover{box-shadow:0 4px 14px rgba(200,68,10,.3)}
.btn-success{background:var(--green);color:white}
.btn-success:hover{box-shadow:0 4px 12px rgba(13,146,101,.3)}
.btn-outline{background:var(--surface);color:var(--ink);border:1.5px solid var(--border)}
.btn-outline:hover{border-color:var(--ink2);background:var(--bg)}
.btn-danger{background:var(--red);color:white}
.btn-danger:hover{box-shadow:0 4px 12px rgba(192,38,29,.3)}
.btn-sm{padding:.38rem .8rem;font-size:.74rem}

/* TABLE */
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:.82rem}
table th{background:var(--surface2);padding:.65rem .85rem;text-align:left;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ink4);border-bottom:1px solid var(--border)}
table td{padding:.65rem .85rem;border-bottom:1px solid var(--border);color:var(--ink2)}
table tr:last-child td{border-bottom:none}
table tr:hover td{background:var(--bg)}
.td-bold{font-weight:700;color:var(--ink)}

/* BADGES */
.badge{display:inline-block;font-size:.68rem;font-weight:700;padding:.2rem .6rem;border-radius:100px;letter-spacing:.03em}
.badge-green{background:var(--green-light);color:var(--green)}
.badge-red{background:var(--red-light);color:var(--red)}
.badge-orange{background:var(--orange-light);color:var(--orange)}
.badge-blue{background:var(--primary-light);color:var(--primary)}
.badge-purple{background:var(--purple-light);color:var(--purple)}
.badge-yellow{background:var(--yellow-light);color:var(--yellow)}

/* PROGRESS BAR */
.progress-bar{height:6px;background:var(--border);border-radius:100px;overflow:hidden;margin-top:.4rem}
.progress-fill{height:100%;border-radius:100px;transition:width .5s ease}

/* ALERT */
.alert{border-radius:var(--radius-sm);padding:.9rem 1.1rem;margin-bottom:.8rem;display:flex;gap:.8rem;align-items:flex-start}
.alert-icon{font-size:1rem;margin-top:.05rem}
.alert-content h4{font-size:.82rem;font-weight:700;margin-bottom:.15rem}
.alert-content p{font-size:.78rem;line-height:1.5;opacity:.85}
.alert-red{background:var(--red-light);color:var(--red)}
.alert-yellow{background:var(--yellow-light);color:var(--yellow)}
.alert-green{background:var(--green-light);color:var(--green)}
.alert-blue{background:var(--primary-light);color:var(--primary)}

/* AI SECTION */
.ai-response{background:linear-gradient(135deg,var(--primary-light) 0%,var(--surface2) 100%);border:1px solid #ffd0b8;border-radius:var(--radius);padding:1.4rem;margin-top:1rem}
.ai-header{display:flex;align-items:center;gap:.7rem;margin-bottom:1rem}
.ai-avatar{width:32px;height:32px;background:linear-gradient(135deg,var(--primary),var(--purple));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.9rem}
.ai-name{font-family:'Fraunces',serif;font-size:.88rem;font-weight:700;color:var(--primary)}
.ai-body{font-size:.85rem;line-height:1.7;color:var(--ink2)}
.ai-body h4{font-size:.82rem;font-weight:700;color:var(--ink);margin:.8rem 0 .3rem}
.ai-body ul{padding-left:1.2rem}
.ai-body li{margin-bottom:.25rem}
.ai-loading{display:flex;align-items:center;gap:.8rem;color:var(--ink3);font-size:.85rem}
.ai-dots span{display:inline-block;width:6px;height:6px;background:var(--primary);border-radius:50%;animation:dot 1.4s infinite}
.ai-dots span:nth-child(2){animation-delay:.2s}
.ai-dots span:nth-child(3){animation-delay:.4s}
@keyframes dot{0%,80%,100%{opacity:.2}40%{opacity:1}}

/* CHART CONTAINERS */
.chart-box{position:relative;height:220px}
.chart-box-tall{position:relative;height:280px}

/* SECTION HEADER */
.section-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:1.2rem}
.section-header h2{font-size:1.1rem;font-weight:700;letter-spacing:-.02em}
.section-header p{font-size:.78rem;color:var(--ink3);margin-top:.15rem}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:500;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{background:var(--surface);border-radius:16px;width:580px;max-width:95vw;max-height:88vh;overflow-y:auto;transform:scale(.96);transition:transform .2s;box-shadow:0 24px 48px rgba(26,18,8,.18)}
.modal-overlay.open .modal{transform:scale(1)}
.modal-header{padding:1.3rem 1.6rem;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:var(--surface);z-index:10}
.modal-header h3{font-size:1rem;font-weight:700}
.modal-close{background:none;border:none;cursor:pointer;font-size:1.2rem;color:var(--ink3)}
.modal-body{padding:1.4rem 1.6rem}
.modal-footer{padding:1rem 1.6rem;border-top:1px solid var(--border);display:flex;gap:.8rem;justify-content:flex-end}

/* TOAST */
.toast{position:fixed;bottom:1.5rem;right:1.5rem;z-index:999;background:var(--ink);color:white;padding:.7rem 1.3rem;border-radius:var(--radius-sm);font-size:.82rem;font-weight:600;transform:translateY(60px);opacity:0;transition:all .3s}
.toast.show{transform:translateY(0);opacity:1}

/* FORECAST */
.forecast-card{background:linear-gradient(135deg,var(--ink) 0%,#2d1a0a 100%);color:white;border-radius:var(--radius);padding:1.4rem}
.forecast-card .fc-label{font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;opacity:.6;margin-bottom:.3rem}
.forecast-card .fc-value{font-size:1.8rem;font-weight:800;letter-spacing:-.03em}
.forecast-card .fc-sub{font-size:.75rem;opacity:.6;margin-top:.2rem}

/* DIVIDER */
.divider{border:none;border-top:1px solid var(--border);margin:1.2rem 0}

/* INPUT INLINE */
.input-inline{padding:.35rem .6rem;border:1.5px solid var(--border);border-radius:6px;font-family:inherit;font-size:.8rem;color:var(--ink);background:var(--bg);outline:none;transition:border-color .2s}
.input-inline:focus{border-color:var(--primary)}

/* EXPLANATION BOX */
.explain-box{background:var(--primary-light);border:1px solid #ffd0b8;border-left:3px solid var(--primary);border-radius:var(--radius-sm);padding:.8rem 1rem;margin-bottom:1.2rem;font-size:.8rem;color:var(--primary);line-height:1.5;display:flex;gap:.6rem;align-items:flex-start}
.explain-box .explain-icon{font-size:1rem;flex-shrink:0;margin-top:.05rem}

/* SHIFT PLANNER */
.shift-grid{display:grid;grid-template-columns:140px repeat(7,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:1.2rem}
.shift-cell{background:var(--surface);padding:.55rem .5rem;font-size:.75rem;display:flex;align-items:center;justify-content:center;min-height:44px;transition:background .15s}
.shift-header{background:var(--surface2);font-weight:700;color:var(--ink2);text-transform:uppercase;letter-spacing:.04em;font-size:.68rem}
.shift-name{justify-content:flex-start;padding-left:.8rem;font-weight:600;color:var(--ink);font-size:.78rem;background:var(--surface2)}
.shift-cell{position:relative}
.shift-cell.assigned{background:#dcfce7;color:#166534;font-weight:700;cursor:pointer;flex-direction:column;gap:2px}
.shift-cell.shift-morgen{background:#dbeafe;color:#1e40af;font-weight:700;cursor:pointer;flex-direction:column;gap:2px}
.shift-cell.shift-mittag{background:#ffedd5;color:#9a3412;font-weight:700;cursor:pointer;flex-direction:column;gap:2px}
.shift-cell.shift-abend{background:#ede9fe;color:#5b21b6;font-weight:700;cursor:pointer;flex-direction:column;gap:2px}
.shift-cell.shift-nacht{background:#1e293b;color:#94a3b8;font-weight:700;cursor:pointer;flex-direction:column;gap:2px}
.shift-cell.wish-free{background:#fef9c3;color:#854d0e;font-weight:600;cursor:pointer;font-size:.68rem}
.shift-cell.unavailable{background:#fee2e2;color:#991b1b;font-size:.7rem;cursor:not-allowed}
.shift-cell.empty{cursor:pointer}
.shift-cell.empty:hover{background:var(--primary-light)}
.shift-cell.today-col{box-shadow:inset 0 -2px 0 var(--primary)}
.shift-cell.overlap-warning{outline:2px solid #dc2626;outline-offset:-2px}
.shift-hours-input{width:36px;border:1px solid rgba(0,0,0,.18);border-radius:4px;font-size:.7rem;font-weight:700;text-align:center;background:rgba(255,255,255,.55);color:inherit;padding:1px 2px;outline:none}
.shift-hours-input:focus{border-color:var(--primary);background:white;color:var(--ink)}
.shift-type-badge{font-size:.55rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;opacity:.75}
.btn-edit{background:none;border:none;cursor:pointer;font-size:.78rem;padding:.2rem .4rem;border-radius:4px;color:var(--primary);transition:background .15s}
.btn-edit:hover{background:var(--primary-light)}
.demand-bar{height:8px;border-radius:100px;background:var(--border);overflow:hidden;margin-top:.3rem}
.demand-fill{height:100%;border-radius:100px;transition:width .4s ease}
.demand-row{display:grid;grid-template-columns:140px repeat(7,1fr);gap:1px;margin-bottom:1.2rem}
.demand-cell{text-align:center;font-size:.72rem;color:var(--ink3);padding:.3rem .4rem}
.demand-cell .demand-label{font-weight:700;margin-bottom:.2rem}
.shift-legend{display:flex;gap:1.2rem;margin-bottom:1rem;flex-wrap:wrap}
.shift-legend-item{display:flex;align-items:center;gap:.4rem;font-size:.72rem;color:var(--ink2)}
.shift-legend-dot{width:12px;height:12px;border-radius:3px}

@media(max-width:900px){
  .sidebar{transform:translateX(-100%);transition:transform .3s}
  .sidebar.open{transform:translateX(0)}
  .main{margin-left:0}
  .kpi-grid{grid-template-columns:1fr 1fr}
  .grid-2,.grid-2-1,.grid-1-2{grid-template-columns:1fr}
  .grid-3{grid-template-columns:1fr}
  .grid-4{grid-template-columns:1fr 1fr}
  .topbar{padding:.8rem 1rem}
  .content{padding:1.2rem 1rem}
}

/* WORKSPACE CARD in sidebar */
.nav-ws-card{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:10px;cursor:pointer;transition:background .14s;border:1px solid rgba(255,255,255,.07)}
.nav-ws-card:hover{background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.12)}
.nav-ws-av{width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,var(--primary),#7c1902);display:flex;align-items:center;justify-content:center;font-family:'Fraunces',serif;font-size:11px;font-weight:900;color:white;flex-shrink:0;letter-spacing:-.02em}
.nav-ws-name{font-size:13px;font-weight:600;color:rgba(255,255,255,.82);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px}
.nav-ws-sub{font-size:10.5px;color:rgba(255,255,255,.28);margin-top:1px}

/* SETTINGS TABS */
.settings-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:1.5rem}
.settings-tab{padding:.7rem 1.2rem;font-size:.82rem;font-weight:600;color:var(--ink3);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:color .15s,border-color .15s;background:none;border-top:none;border-left:none;border-right:none;font-family:inherit}
.settings-tab:hover{color:var(--ink2)}
.settings-tab.active{color:var(--primary);border-bottom-color:var(--primary)}
.settings-panel{display:none}
.settings-panel.active{display:block}

/* INTEGRATION CARD */
.integration-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);padding:1.2rem 1.4rem;display:flex;align-items:center;gap:1rem;transition:border-color .2s,box-shadow .2s;margin-bottom:.8rem}
.integration-card:hover{border-color:var(--border2);box-shadow:var(--shadow)}
.integration-card.connected{border-color:#b7dfcc;background:var(--green-light)}
.integration-card.coming{opacity:.55}
.integration-logo{width:44px;height:44px;border-radius:10px;object-fit:contain;border:1px solid var(--border);background:white;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-weight:800;font-size:.72rem;color:var(--ink3)}
.integration-info{flex:1}
.integration-name{font-size:.9rem;font-weight:700;color:var(--ink)}
.integration-desc{font-size:.78rem;color:var(--ink3);margin-top:.15rem;line-height:1.4}
.integration-status{font-size:.68rem;font-weight:700;padding:.2rem .7rem;border-radius:100px;white-space:nowrap}
.int-connected{background:var(--green-light);color:var(--green);border:1px solid #b7dfcc}
.int-soon{background:var(--yellow-light);color:var(--yellow);border:1px solid #e9d584}
.int-available{background:var(--surface2);color:var(--ink3);border:1px solid var(--border)}
.btn-connect{padding:.45rem .9rem;border-radius:100px;font-size:.76rem;font-weight:600;cursor:pointer;font-family:inherit;border:1.5px solid var(--border);background:var(--surface);color:var(--ink2);transition:all .15s;white-space:nowrap}
.btn-connect:hover{border-color:var(--primary);color:var(--primary)}
.btn-connect.primary{background:var(--primary);color:white;border-color:var(--primary)}
.btn-connect.primary:hover{background:var(--orange-light)!important;color:var(--primary)!important;border-color:var(--primary)!important}

/* OPENING HOURS GRID */
.hours-grid{display:grid;grid-template-columns:100px 1fr 1fr 80px;gap:.5rem;align-items:center;margin-bottom:.4rem}
.hours-day{font-size:.82rem;font-weight:600;color:var(--ink2)}
.hours-sep{text-align:center;color:var(--ink4);font-size:.8rem}
.toggle-switch{position:relative;width:38px;height:22px;cursor:pointer}
.toggle-switch input{display:none}
.toggle-track{position:absolute;inset:0;background:var(--border2);border-radius:100px;transition:background .2s}
.toggle-switch input:checked + .toggle-track{background:var(--green)}
.toggle-thumb{position:absolute;top:3px;left:3px;width:16px;height:16px;background:white;border-radius:50%;transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.2)}
.toggle-switch input:checked ~ .toggle-thumb{left:19px}

/* TOP BAR HEIGHT fix */
.topbar-left h1{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:900;letter-spacing:-.03em}


/* ── CSV IMPORT MODAL ── */
.csv-modal { width: 720px !important; }
.csv-step { display:none }
.csv-step.active { display:block }
.step-indicator { display:flex; align-items:center; gap:0; margin-bottom:1.5rem }
.step-dot { display:flex; align-items:center; gap:8px; font-size:.78rem; font-weight:600; color:var(--ink4) }
.step-dot.active { color:var(--primary) }
.step-dot.done { color:var(--green) }
.step-dot span { width:24px; height:24px; border-radius:50%; border:2px solid currentColor;
  display:flex; align-items:center; justify-content:center; font-size:.7rem; font-weight:800; flex-shrink:0 }
.step-line { flex:1; height:1px; background:var(--border); margin:0 8px }

/* Drop zone */
.drop-zone { border:2px dashed var(--border2); border-radius:var(--radius);
  padding:2.5rem 1.5rem; text-align:center; cursor:pointer; transition:all .2s;
  background:var(--surface2) }
.drop-zone:hover, .drop-zone.dragover { border-color:var(--primary); background:var(--primary-light) }
.drop-zone svg { width:36px; height:36px; stroke:var(--ink4); margin-bottom:.8rem }
.drop-zone.dragover svg { stroke:var(--primary) }
.drop-title { font-size:.9rem; font-weight:700; color:var(--ink2); margin-bottom:.3rem }
.drop-sub { font-size:.78rem; color:var(--ink3) }

/* Column mapping table */
.col-map-table { width:100%; border-collapse:collapse; font-size:.8rem }
.col-map-table th { font-size:.68rem; font-weight:700; text-transform:uppercase;
  letter-spacing:.07em; color:var(--ink4); padding:.5rem .6rem; background:var(--surface2);
  border-bottom:1px solid var(--border) }
.col-map-table td { padding:.5rem .6rem; border-bottom:1px solid var(--cream2); vertical-align:middle }
.col-map-table tr:last-child td { border:none }
.col-map-table select { font-size:.78rem; padding:.3rem .5rem; border:1.5px solid var(--border);
  border-radius:6px; background:var(--bg); font-family:inherit; color:var(--ink); outline:none }
.col-map-table select:focus { border-color:var(--primary) }
.col-preview { font-size:.75rem; color:var(--ink3); font-style:italic; margin-top:1px }
.col-field-name { font-weight:600; color:var(--ink) }
.col-required { font-size:.65rem; color:var(--red); margin-left:3px }

/* Conflict table */
.conflict-table { width:100%; border-collapse:collapse; font-size:.78rem }
.conflict-table th { font-size:.67rem; font-weight:700; text-transform:uppercase;
  letter-spacing:.06em; color:var(--ink4); padding:.45rem .6rem; background:var(--surface2);
  border-bottom:1px solid var(--border); white-space:nowrap }
.conflict-table td { padding:.5rem .6rem; border-bottom:1px solid var(--cream2); vertical-align:middle }
.conflict-table tr:last-child td { border:none }
.conflict-table tr.will-skip td { opacity:.45 }
.cfl-old { color:var(--ink3) }
.cfl-new { color:var(--ink); font-weight:600 }
.cfl-diff-up { color:var(--green); font-weight:700 }
.cfl-diff-dn { color:var(--red); font-weight:700 }
.resolve-btn { padding:.25rem .6rem; border-radius:100px; font-size:.7rem; font-weight:700;
  cursor:pointer; border:1.5px solid var(--border); background:var(--surface); font-family:inherit;
  transition:all .15s; white-space:nowrap }
.resolve-btn.keep { border-color:var(--green); color:var(--green); background:var(--green-light) }
.resolve-btn.overwrite { border-color:var(--red); color:var(--red); background:var(--red-light) }
.resolve-btn.merge { border-color:var(--primary); color:var(--primary); background:var(--primary-light) }

/* Import summary */
.import-summary-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:.8rem; margin-bottom:1.2rem }
.imp-stat { text-align:center; padding:.8rem; background:var(--surface2);
  border-radius:var(--radius-sm); border:1px solid var(--border) }
.imp-stat-num { font-family:'Fraunces',serif; font-size:1.6rem; font-weight:900;
  color:var(--ink); letter-spacing:-.04em }
.imp-stat-lbl { font-size:.68rem; color:var(--ink3); text-transform:uppercase;
  letter-spacing:.06em; margin-top:2px }

/* Import log table in settings */
.import-log-row { display:flex; align-items:center; gap:10px;
  padding:9px 0; border-bottom:1px solid var(--cream2); font-size:.8rem }
.import-log-row:last-child { border:none }
.import-log-icon { width:30px; height:30px; border-radius:7px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center; font-size:.68rem; font-weight:800 }
.log-ts { color:var(--ink3); font-size:.72rem; white-space:nowrap }
.log-badge { font-size:.67rem; font-weight:700; padding:.15rem .55rem; border-radius:100px }

/* ── POS AGGREGATION MODE ── */
.pos-mode-banner { background:var(--primary-light,#eff6ff); border:1.5px solid var(--primary);
  border-radius:var(--radius-sm); padding:.75rem 1rem; margin-bottom:1rem; display:flex; align-items:flex-start; gap:.7rem }
.pos-mode-banner .pos-icon { font-size:1.2rem; margin-top:.05rem; flex-shrink:0 }
.pos-mode-title { font-weight:700; font-size:.85rem; color:var(--primary); margin-bottom:.25rem }
.pos-mode-sub { font-size:.78rem; color:var(--ink2); line-height:1.5 }
.pos-stats-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:.6rem; margin:.8rem 0 }
.pos-stat { background:var(--surface2); border:1px solid var(--border); border-radius:8px;
  padding:.55rem .7rem; text-align:center }
.pos-stat-num { font-size:1.15rem; font-weight:800; color:var(--ink) }
.pos-stat-lbl { font-size:.68rem; color:var(--ink3); margin-top:.1rem }
.pos-warnings-box { background:#fff7ed; border:1px solid var(--orange); border-radius:8px;
  padding:.7rem .9rem; margin-top:.7rem; font-size:.78rem; color:var(--ink2) }
.pos-warn-item { display:flex; gap:.5rem; align-items:flex-start; margin-bottom:.3rem }
.pos-warn-item:last-child { margin-bottom:0 }
.pos-warn-item .wi { flex-shrink:0; margin-top:.05rem }
.pos-err-box { background:#fff1f2; border:1px solid var(--red); border-radius:8px;
  padding:.7rem .9rem; margin-top:.5rem; font-size:.78rem; color:var(--ink2); max-height:140px; overflow-y:auto }
.pos-err-item { padding:.2rem 0; border-bottom:1px solid rgba(0,0,0,.05); font-family:monospace; font-size:.72rem }

/* ── VALIDATION HINTS (form) ── */
.val-hint { font-size:.73rem; margin-top:.25rem; padding:.3rem .6rem; border-radius:6px; display:none }
.val-hint.error { background:#fff1f2; color:var(--red); border:1px solid #fecdd3; display:block }
.val-hint.warning { background:#fff7ed; color:#92400e; border:1px solid #fed7aa; display:block }
.val-hint.ok { background:#f0fdf4; color:#166534; border:1px solid #bbf7d0; display:block }

/* ── DATA QUALITY WIDGET ── */
.dq-widget { background:var(--surface); border:1.5px solid var(--border); border-radius:var(--radius-sm);
  padding:.8rem 1rem; margin-bottom:1.2rem }
.dq-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:.6rem }
.dq-title { font-weight:700; font-size:.82rem; color:var(--ink) }
.dq-pct { font-weight:800; font-size:1.05rem }
.dq-bar-track { height:8px; border-radius:100px; background:var(--cream2); overflow:hidden }
.dq-bar-fill { height:100%; border-radius:100px; transition:width .4s }
.dq-legend { display:flex; gap:.8rem; margin-top:.55rem; flex-wrap:wrap }
.dq-leg { display:flex; align-items:center; gap:.3rem; font-size:.72rem; color:var(--ink3) }
.dq-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0 }
.dq-missing-hint { margin-top:.5rem; font-size:.75rem; color:var(--red); font-weight:600 }
.we-missing-badge { display:inline-flex; align-items:center; gap:.35rem; background:#fff7ed;
  border:1px solid var(--orange); border-radius:6px; padding:.25rem .6rem;
  font-size:.72rem; font-weight:700; color:#92400e; cursor:pointer }

/* Profile save */
.profile-save-row { display:flex; gap:.6rem; align-items:center; margin-top:1rem;
  padding-top:1rem; border-top:1px solid var(--border) }
.profile-save-row input { flex:1; padding:.42rem .7rem; border:1.5px solid var(--border);
  border-radius:var(--radius-sm); font-family:inherit; font-size:.8rem; background:var(--surface2) }

/* All conflicts bulk actions */
.bulk-resolve { display:flex; gap:.5rem; margin-bottom:.8rem; align-items:center }
.bulk-resolve span { font-size:.76rem; color:var(--ink3); margin-right:.3rem }

</style>
</head>
