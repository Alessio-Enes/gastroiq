let dashCharts = {};
function renderDashboard() {
  renderRestaurantBanner();
  const m = getCurrentMonth();
  const d = getMonthData(m);

  // ── Umsatz ──
  document.getElementById('kpi-umsatz').textContent = fmtEur(d.umsatz);
  const umsatzTage = document.getElementById('kpi-umsatz-tage');
  if(umsatzTage) umsatzTage.textContent = d.tageCount + ' Tage erfasst';
  const ud = document.getElementById('kpi-umsatz-d');
  ud.textContent = d.umsatz > 0 ? 'Ø ' + fmtEur(d.tageCount > 0 ? d.umsatz / d.tageCount : 0) + ' / Tag' : '–';
  ud.className = 'kpi-delta neutral';

  // ── Rohgewinn ──
  document.getElementById('kpi-db').textContent = fmtEur(d.db);
  const dbAbs = document.getElementById('kpi-db-abs');
  if(dbAbs) dbAbs.textContent = d.umsatz > 0 ? fmtPct(d.db / d.umsatz * 100) + ' von ' + fmtEur(d.umsatz) + ' Umsatz' : '–';
  const dbd = document.getElementById('kpi-db-d');
  dbd.textContent = d.db >= 0 ? '✅ Positiver Deckungsbeitrag' : '🔴 Deckungsbeitrag negativ';
  dbd.className = 'kpi-delta ' + (d.db > 0 ? 'up' : 'down');

  // ── Wareneinsatz ──
  document.getElementById('kpi-fc').textContent = fmtPct(d.foodCostPct);
  document.getElementById('kpi-fc-abs').textContent = fmtEur(d.einkaufGesamt) + ' von ' + fmtEur(d.umsatz) + ' Umsatz';
  const fcd = document.getElementById('kpi-fc-d');
  fcd.textContent = d.foodCostPct > 30 ? '⚠️ Zu hoch – Ziel: unter 30%' : '✅ Im grünen Bereich';
  fcd.className = 'kpi-delta ' + (d.foodCostPct > 30 ? 'down' : 'up');

  // ── Ø Bon ──
  document.getElementById('kpi-bon').textContent = fmtEur(d.avgBon);
  const bonAbs = document.getElementById('kpi-bon-abs');
  if(bonAbs) bonAbs.textContent = d.gaeste > 0 ? 'bei ' + d.gaeste.toLocaleString('de-DE') + ' Gästen' : '–';
  const bond = document.getElementById('kpi-bon-d');
  const bonZiel = state.settings.bonZiel || 22;
  bond.textContent = 'Ziel: ' + fmtEur(bonZiel) + (d.avgBon >= bonZiel ? ' ✅' : ' – noch ' + fmtEur(bonZiel - d.avgBon) + ' fehlen');
  bond.className = 'kpi-delta ' + (d.avgBon >= bonZiel ? 'up' : 'down');

  // ── Personalkosten ──
  document.getElementById('kpi-pk').textContent = fmtPct(d.personalPct);
  document.getElementById('kpi-pk-abs').textContent = fmtEur(d.personalGesamt) + ' von ' + fmtEur(d.umsatz) + ' Umsatz';
  const pkd = document.getElementById('kpi-pk-d');
  const pkZiel = state.settings.pkZiel || 35;
  pkd.textContent = d.personalPct > pkZiel ? '⚠️ Zu hoch – Ziel: unter ' + pkZiel + '%' : '✅ Im grünen Bereich';
  pkd.className = 'kpi-delta ' + (d.personalPct > pkZiel ? 'down' : 'up');

  // ── Fixkosten ──
  document.getElementById('kpi-fkq').textContent = fmtPct(d.fixPct);
  document.getElementById('kpi-fk-abs').textContent = fmtEur(d.fixkostenGesamt) + ' von ' + fmtEur(d.umsatz) + ' Umsatz';
  const fkd = document.getElementById('kpi-fk-d');
  if(fkd) { fkd.textContent = 'Monatliche Fixkosten'; fkd.className = 'kpi-delta neutral'; }

  // ── Betriebsergebnis ──
  document.getElementById('kpi-ebit').textContent = fmtEur(d.ebit);
  const ebitAbs = document.getElementById('kpi-ebit-abs');
  if(ebitAbs) {
    const gesamtkosten = d.einkaufGesamt + d.personalGesamt + d.fixkostenGesamt;
    ebitAbs.textContent = fmtEur(d.umsatz) + ' − ' + fmtEur(gesamtkosten) + ' Kosten';
  }
  const ebitd = document.getElementById('kpi-ebit-d');
  ebitd.textContent = d.ebit >= 0 ? '✅ Dein Laden verdient Geld!' : '🔴 Achtung: Du machst Verlust';
  ebitd.className = 'kpi-delta ' + (d.ebit >= 0 ? 'up' : 'down');

  // ── Gäste ──
  document.getElementById('kpi-gaeste').textContent = d.gaeste.toLocaleString('de-DE');
  const gaesAbs = document.getElementById('kpi-gaeste-abs');
  if(gaesAbs) gaesAbs.textContent = d.umsatz > 0 ? fmtEur(d.umsatz) + ' Gesamtumsatz' : '–';
  const gd = document.getElementById('kpi-gaeste-d');
  gd.textContent = d.tageCount > 0 ? 'Ø ' + Math.round(d.gaeste / d.tageCount) + ' Gäste / Tag' : '–';
  gd.className = 'kpi-delta neutral';

  renderAlerts(d);

  // ── Liniendiagramm: Umsatz Monatsverlauf ──
  const te = state.tageseintraege.filter(t => monthStr(t.datum) === m).sort((a, b) => a.datum.localeCompare(b.datum));
  const labels = te.map(t => t.datum.substr(8));
  const uData = te.map(t => t.umsatz || 0);
  destroyChart('chart-umsatz');
  const ctx1 = document.getElementById('chart-umsatz');
  if(ctx1) dashCharts['chart-umsatz'] = new Chart(ctx1, {
    type: 'line',
    data: { labels, datasets: [{ label: 'Umsatz (€)', data: uData, borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,.08)', tension: .4, fill: true, pointRadius: 3 }] },
    options: { ...chartOpts(), plugins: { legend: { display: false } } }
  });

  // ── Balkendiagramm: Top 5 Gerichte (nach Häufigkeit in Tageseinträgen) ──
  const gerichtCounts = {};
  te.forEach(t => { if(t.topGericht) gerichtCounts[t.topGericht] = (gerichtCounts[t.topGericht] || 0) + 1; });
  const sorted = Object.entries(gerichtCounts).sort((a, b) => b[1] - a[1]).slice(0, 5);
  destroyChart('chart-topgerichte');
  const ctx2 = document.getElementById('chart-topgerichte');
  if(ctx2) dashCharts['chart-topgerichte'] = new Chart(ctx2, {
    type: 'bar',
    data: {
      labels: sorted.map(s => s[0]),
      datasets: [{ label: 'Tage als Top-Gericht', data: sorted.map(s => s[1]), backgroundColor: ['#2563eb','#16a34a','#ea580c','#7c3aed','#ca8a04'] }]
    },
    options: {
      ...chartOpts(),
      indexAxis: 'y',
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: ctx => ctx.parsed.x + ' Tage als Tagesgericht' } }
      }
    }
  });

  // ── Kuchendiagramm: Speisekarte nach Typ (Vegan/Fleisch/Fisch) ──
  const vegan   = state.gerichte.filter(g => g.typ === 'vegan' || g.typ === 'vegetarisch').length;
  const fleisch = state.gerichte.filter(g => g.typ === 'fleisch').length;
  const fisch   = state.gerichte.filter(g => g.typ === 'fisch').length;
  const gesamtGerichte = vegan + fleisch + fisch;
  destroyChart('chart-gericht-typen');
  const ctx3 = document.getElementById('chart-gericht-typen');
  if(ctx3) dashCharts['chart-gericht-typen'] = new Chart(ctx3, {
    type: 'doughnut',
    data: {
      labels: [
        'Vegan / Vegetarisch (' + vegan + ')',
        'Fleisch (' + fleisch + ')',
        'Fisch (' + fisch + ')'
      ],
      datasets: [{ data: [vegan, fleisch, fisch], backgroundColor: ['#0d9265','#d95f0a','#1a56db'], borderWidth:2, borderColor:'#fff' }]
    },
    options: {
      ...pieChartOpts('bottom'),
      plugins: {
        ...pieChartOpts('bottom').plugins,
        tooltip: { callbacks: { label: ctx => ctx.label + ' – ' + (gesamtGerichte > 0 ? Math.round(ctx.parsed / gesamtGerichte * 100) : 0) + '%' } }
      }
    }
  });

  // ── Kuchendiagramm: To-Go vs. Inhouse (Bestellungen im Monat) ──
  const togoCount   = te.reduce((s, t) => s + (t.togo || 0), 0);
  const inhouseCount = te.reduce((s, t) => s + (t.gaeste || 0), 0);
  const gesamtBestellungen = togoCount + inhouseCount;
  destroyChart('chart-togo');
  const ctx4 = document.getElementById('chart-togo');
  if(ctx4) dashCharts['chart-togo'] = new Chart(ctx4, {
    type: 'doughnut',
    data: {
      labels: [
        'To-Go (' + togoCount.toLocaleString('de-DE') + ')',
        'Inhouse (' + inhouseCount.toLocaleString('de-DE') + ')'
      ],
      datasets: [{ data: [togoCount, inhouseCount], backgroundColor: ['#6d28d9','#a16207'], borderWidth:2, borderColor:'#fff' }]
    },
    options: {
      ...pieChartOpts('bottom'),
      plugins: {
        ...pieChartOpts('bottom').plugins,
        tooltip: { callbacks: { label: ctx => ctx.label + ' – ' + (gesamtBestellungen > 0 ? Math.round(ctx.parsed / gesamtBestellungen * 100) : 0) + '%' } }
      }
    }
  });

  // ── Kuchendiagramm: Kostenverteilung ──
  destroyChart('chart-kosten');
  const ctx5 = document.getElementById('chart-kosten');
  if(ctx5) dashCharts['chart-kosten'] = new Chart(ctx5, {
    type: 'doughnut',
    data: {
      labels: [
        'Zutaten (' + fmtEur(d.einkaufGesamt) + ')',
        'Personal (' + fmtEur(d.personalGesamt) + ')',
        'Fixkosten (' + fmtEur(d.fixkostenGesamt) + ')',
        'Gewinn (' + fmtEur(Math.max(0, d.ebit)) + ')'
      ],
      datasets: [{ data: [d.einkaufGesamt, d.personalGesamt, d.fixkostenGesamt, Math.max(0, d.ebit)], backgroundColor: ['#d95f0a','#c0261d','#6d28d9','#0d9265'], borderWidth:2, borderColor:'#fff' }]
    },
    options: {
      ...pieChartOpts('bottom'),
      plugins: {
        ...pieChartOpts('bottom').plugins,
        tooltip: { callbacks: { label: ctx => ctx.label + ' – ' + (d.umsatz > 0 ? Math.round(ctx.parsed / d.umsatz * 100) : 0) + '% vom Umsatz' } }
      }
    }
  });

  renderZahlungsarten(m);
}

// ── ZAHLUNGSARTEN (Bar / Karte / Digital) ────────────────────
function renderZahlungsarten(monat) {
  const el = document.getElementById('zahlungsarten-content');
  const card = document.getElementById('zahlungsarten-card');
  if (!el) return;

  const te = (state.tageseintraege || []).filter(t => (t.datum || '').startsWith(monat));
  const bar     = te.reduce((s, t) => s + (t.barUmsatz || 0), 0);
  const karte   = te.reduce((s, t) => s + (t.karteUmsatz || 0), 0);
  const digital = te.reduce((s, t) => s + (t.digitalUmsatz || 0), 0);
  const gesamt  = bar + karte + digital;

  if (gesamt < 0.01) {
    el.innerHTML = `<div style="text-align:center;padding:1.2rem;color:var(--ink3);font-size:.82rem">
      Noch keine Zahlungsarten-Daten für diesen Monat erfasst.<br>
      <span style="font-size:.75rem">Beim Tageseintrag Bar/Karte/Digital ausfüllen oder CSV mit Zahlungsart importieren.</span>
    </div>`;
    return;
  }

  const barPct     = Math.round(bar / gesamt * 100);
  const kartePct   = Math.round(karte / gesamt * 100);
  const digitalPct = Math.round(digital / gesamt * 100);

  el.innerHTML = `
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.2rem">
      <div style="background:#f0fdf4;border:1.5px solid #bbf7d0;border-radius:10px;padding:1rem 1.1rem;text-align:center">
        <div style="font-size:1.5rem;margin-bottom:.3rem">💵</div>
        <div style="font-size:1.35rem;font-weight:800;color:#166534;font-family:'Fraunces',serif">${fmtEur(bar)}</div>
        <div style="font-size:.72rem;color:#16a34a;font-weight:700;margin-top:.2rem">BAR</div>
        <div style="font-size:1.1rem;font-weight:700;color:#166534;margin-top:.3rem">${barPct}%</div>
        <div style="height:5px;background:#dcfce7;border-radius:100px;margin-top:.5rem;overflow:hidden">
          <div style="height:100%;width:${barPct}%;background:#16a34a;border-radius:100px"></div>
        </div>
      </div>
      <div style="background:#eff6ff;border:1.5px solid #bfdbfe;border-radius:10px;padding:1rem 1.1rem;text-align:center">
        <div style="font-size:1.5rem;margin-bottom:.3rem">💳</div>
        <div style="font-size:1.35rem;font-weight:800;color:#1e40af;font-family:'Fraunces',serif">${fmtEur(karte)}</div>
        <div style="font-size:.72rem;color:#3b82f6;font-weight:700;margin-top:.2rem">KARTE</div>
        <div style="font-size:1.1rem;font-weight:700;color:#1e40af;margin-top:.3rem">${kartePct}%</div>
        <div style="height:5px;background:#dbeafe;border-radius:100px;margin-top:.5rem;overflow:hidden">
          <div style="height:100%;width:${kartePct}%;background:#3b82f6;border-radius:100px"></div>
        </div>
      </div>
      <div style="background:#faf5ff;border:1.5px solid #e9d5ff;border-radius:10px;padding:1rem 1.1rem;text-align:center">
        <div style="font-size:1.5rem;margin-bottom:.3rem">📱</div>
        <div style="font-size:1.35rem;font-weight:800;color:#6b21a8;font-family:'Fraunces',serif">${fmtEur(digital)}</div>
        <div style="font-size:.72rem;color:#9333ea;font-weight:700;margin-top:.2rem">DIGITAL</div>
        <div style="font-size:1.1rem;font-weight:700;color:#6b21a8;margin-top:.3rem">${digitalPct}%</div>
        <div style="height:5px;background:#f3e8ff;border-radius:100px;margin-top:.5rem;overflow:hidden">
          <div style="height:100%;width:${digitalPct}%;background:#9333ea;border-radius:100px"></div>
        </div>
      </div>
    </div>
    <div style="background:var(--surface2);border-radius:8px;padding:.65rem 1rem;display:flex;justify-content:space-between;align-items:center">
      <span style="font-size:.78rem;color:var(--ink3)">Gesamt erfasste Zahlungen</span>
      <strong style="font-size:.88rem">${fmtEur(gesamt)}</strong>
    </div>
    ${Math.abs(gesamt - te.reduce((s,t)=>s+(t.umsatz||0),0)) > 1 ? `
    <div style="font-size:.73rem;color:var(--orange);margin-top:.5rem;padding:.4rem .7rem;background:#fff7ed;border-radius:6px;border:1px solid var(--orange)">
      ⚠️ Summe der Zahlungsarten weicht vom Gesamtumsatz ab – bitte prüfen
    </div>` : ''}
  `;
}

function renderAlerts(d) {
  const container = document.getElementById('alerts-container');
  const alerts = [];
  if(d.foodCostPct > (state.settings.fcZiel||28)) alerts.push({type:'red',icon:'🚨',title:'Zutatenkosten zu hoch',text:`${fmtPct(d.foodCostPct)} – dein Ziel ist ${state.settings.fcZiel||28}%. Prüfe Einkaufspreise und Portionsgrößen.`});
  if(d.personalPct > (state.settings.pkZiel||33)) alerts.push({type:'red',icon:'⚠️',title:'Personalkosten zu hoch',text:`${fmtPct(d.personalPct)} vom Umsatz gehen an dein Team. Schichtplan prüfen.`});
  if(d.ebit < 0) alerts.push({type:'red',icon:'🔴',title:'Du machst Verlust',text:`${fmtEur(Math.abs(d.ebit))} Minus diesen Monat – sofort handeln.`});
  if(d.avgBon > 0 && d.avgBon < (state.settings.bonZiel||22)) alerts.push({type:'yellow',icon:'📉',title:'Gäste geben zu wenig aus',text:`Ø Bon ${fmtEur(d.avgBon)} – Ziel ist ${fmtEur(state.settings.bonZiel||22)}. Tipp: Desserts und Getränke aktiv empfehlen.`});
  if(d.tageCount < 5) alerts.push({type:'blue',icon:'📝',title:'Mehr Daten nötig',text:'Trag jeden Tag deinen Umsatz ein – dann werden die Analysen genauer.'});
  if(alerts.length===0) alerts.push({type:'green',icon:'✅',title:'Alles im grünen Bereich',text:'Keine Auffälligkeiten – weiter so!'});
  container.innerHTML = alerts.map(a=>`<div class="alert alert-${a.type}"><span class="alert-icon">${a.icon}</span><div class="alert-content"><h4>${a.title}</h4><p>${a.text}</p></div></div>`).join('');
}

