function csvDragover(e) {
  e.preventDefault();
  document.getElementById('csv-dropzone').classList.add('dragover');
}
function csvDragleave(e) {
  document.getElementById('csv-dropzone').classList.remove('dragover');
}
function csvDrop(e) {
  e.preventDefault();
  document.getElementById('csv-dropzone').classList.remove('dragover');
  const file = e.dataTransfer.files[0];
  if (file) csvLoadFile(file);
}
function csvFileSelected(input) {
  if (input.files[0]) csvLoadFile(input.files[0]);
}
function csvLoadFile(file) {
  csvState.fileName = file.name;
  const reader = new FileReader();
  reader.onload = e => {
    csvState.rawText = e.target.result;
    csvAutoDetectSeparator();
    csvParse();
    csvAutoDetectColumns();
    csvGoTo(2);
  };
  reader.readAsText(file, 'UTF-8');
}

// ── PARSING ──────────────────────────────────────────────────
function csvAutoDetectSeparator() {
  const sample = csvState.rawText.split('\n')[0];
  const counts = { ',': (sample.match(/,/g)||[]).length, ';': (sample.match(/;/g)||[]).length, '\t': (sample.match(/\t/g)||[]).length };
  csvState.separator = Object.entries(counts).sort((a,b) => b[1]-a[1])[0][0];
  const sep = document.getElementById('csv-sep');
  if (sep) sep.value = csvState.separator === '\t' ? '\t' : csvState.separator;
}

function csvParse() {
  const sep = csvState.separator;
  const lines = csvState.rawText.trim().split('\n').filter(l => l.trim());
  if (lines.length < 2) { toast('CSV hat zu wenig Zeilen'); return; }
  csvState.headers = csvSplitLine(lines[0], sep);
  csvState.rows = lines.slice(1).map(l => csvSplitLine(l, sep));
}

function csvSplitLine(line, sep) {
  // Handle quoted fields
  const result = [];
  let cur = '', inQ = false;
  for (let i = 0; i < line.length; i++) {
    const c = line[i];
    if (c === '"') { inQ = !inQ; }
    else if (c === sep && !inQ) { result.push(cur.trim()); cur = ''; }
    else { cur += c; }
  }
  result.push(cur.trim());
  return result;
}

function csvReParse() {
  csvState.separator = document.getElementById('csv-sep').value;
  csvParse();
  csvAutoDetectColumns();
  csvRenderColMap();
}

// ── AUTO-DETECT COLUMN NAMES ─────────────────────────────────
const COL_PATTERNS = {
  datum:       [/datum/i, /date/i, /tag/i, /day/i, /zeit/i, /period/i, /geschaeftstag/i, /business.?date/i],
  umsatz:      [/umsatz/i, /revenue/i, /netto/i, /brutto/i, /total/i, /einnahmen/i, /sales/i, /betrag/i, /amount/i, /sum/i],
  gaeste:      [/gäste/i, /gaeste/i, /covers/i, /guests/i, /kunden/i, /persons/i, /transactions/i, /receipts/i, /count/i, /anz/i],
  togo:        [/togo/i, /to.go/i, /lieferung/i, /delivery/i, /takeaway/i, /abholung/i],
  getraenke:   [/getr[äa]nke/i, /drinks/i, /beverages/i, /getränke/i],
  topGericht:  [/gericht/i, /dish/i, /artikel/i, /item/i, /top/i, /bestseller/i],
  notiz:       [/notiz/i, /note/i, /kommentar/i, /comment/i, /anmerkung/i, /remark/i],
};

function csvAutoDetectColumns() {
  const map = { datum: '', umsatz: '', gaeste: '', togo: '', getraenke: '', topGericht: '', notiz: '' };
  csvState.headers.forEach(h => {
    Object.entries(COL_PATTERNS).forEach(([field, patterns]) => {
      if (!map[field] && patterns.some(p => p.test(h))) {
        map[field] = h;
      }
    });
  });
  // If profile loaded, use that
  if (csvState.profileLoaded) {
    Object.assign(map, csvState.profileLoaded.colMap);
  }
  csvState.colMap = map;
  csvState.posMode = csvIsPOSMode();
}

function csvRenderColMap() {
  const headers = csvState.headers;
  const firstRow = csvState.rows[0] || [];

  // Update file info (always)
  document.getElementById('csv-file-info').textContent = csvState.fileName;
