function calcShiftHours() {
  const s = document.getElementById('schicht-start').value;
  const e = document.getElementById('schicht-end').value;
  if(!s || !e) return;
  let [sh,sm] = s.split(':').map(Number), [eh,em] = e.split(':').map(Number);
  let diff = (eh*60+em) - (sh*60+sm);
  if(diff < 0) diff += 24*60; // overnight shift
  document.getElementById('schicht-hours').value = Math.round(diff/60*10)/10;
  checkShiftOverlapPreview(_schichtEmpId, _schichtDateStr, s, e);
}

function validateShichtHours(input) {
