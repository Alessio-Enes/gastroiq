function remapGericht(r)      { return { id:r.id, name:r.name, kategorie:r.kategorie, typ:r.typ, vkPreis:r.vk_preis, wareneinsatz:r.wareneinsatz, togo:r.togo?1:0, beliebtheit:r.beliebtheit }; }
function remapPersonal(r)     { return { id:r.id, name:r.name, rolle:r.rolle, lohn:r.lohn, stunden:r.stunden }; }
function remapTageseintrag(r) { return { id:r.id, datum:r.datum, umsatz:r.umsatz, gaeste:r.gaeste, togo:r.togo, getraenke:r.getraenke, topGericht:r.top_gericht, notiz:r.notiz }; }
function remapVerbrauch(r)    { return { id:r.id, artikel:r.artikel, kategorie:r.kategorie, einkauf:r.einkauf, verbrauch:r.verbrauch, datum:r.datum }; }
function remapFixkosten(r)    { return { id:r.id, art:r.art, betrag:r.betrag, monat:r.monat, typ:r.typ }; }
function remapSettings(r)     { return { name:r.name, typ:r.type, sitze:r.sitze||40, tage:r.tage||6, fcZiel:r.fc_ziel||28, pkZiel:r.pk_ziel||33, bonZiel:r.bon_ziel||22, gasteZiel:r.gaste_ziel||60 }; }

function uid() { return Math.random().toString(36).substr(2,9); }
function fmt(n,d=2) { return (n||0).toLocaleString('de-DE',{minimumFractionDigits:d,maximumFractionDigits:d}); }
function fmtEur(n) { return fmt(n,2)+' €'; }
function fmtPct(n) { return fmt(n,1)+'%'; }
function today() { return new Date().toISOString().split('T')[0]; }
function monthStr(d) { return d ? d.substr(0,7) : ''; }
function getCurrentMonth() { return document.getElementById('currentMonth').value; }

// ════════════════════════════════════════════════════
// DRILLDOWN NAVIGATION
// ════════════════════════════════════════════════════
const pageTitles = {
  dashboard:['Kennzahlen','Ihr Restaurant auf einen Blick'],
  briefing:['Morgenbriefing','Täglicher Lagebericht'],
  tageserfassung:['Tageserfassung','Einnahmen und Gäste eintragen'],
